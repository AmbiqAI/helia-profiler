# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test / coverage
.pytest_cache/
htmlcov/
.coverage

# Generated firmware working directories
hpx_*/

# Profiling results (local runs)
results/

# uv
uv.lock
site/

# Profiling outputs (any location) — consolidate under results/ when possible
**/results_*/
**/work_*/
**/sweep_*/
**/validation_results_*/

# Personal scratch runners (hardcoded paths)
run_*.py

# Developer-local profiler configs (see local-configs/README.md)
local-configs/*
!local-configs/README.md

# Developer-local experiment scripts and outputs.  These are intentionally
# out of version control: ad-hoc runners with hardcoded paths/SHAs, sweeps,
# scratch notebooks, etc.  Each tracked subdir keeps its README.md so the
# folder layout itself is discoverable.
local-scripts/*
!local-scripts/README.md
local-experiments/*
!local-experiments/README.md
