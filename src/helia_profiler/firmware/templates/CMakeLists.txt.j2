{# CMakeLists.txt — top-level CMake for the profiler NSX app #}
# Auto-generated by heliaPROFILER — do not edit.
cmake_minimum_required(VERSION 3.24)
project(hpx_profiler LANGUAGES C CXX ASM)

{% set psram_needed = (arena_region == "psram") or (weights_region == "psram") %}
set(NSX_BOARD "{{ board }}" CACHE STRING "Target board")

{% for var_name, var_value in cmake_vars.items() %}
set({{ var_name }} "{{ var_value }}")
{% endfor %}

include(${CMAKE_CURRENT_LIST_DIR}/cmake/nsx/modules.cmake)
include(${CMAKE_CURRENT_LIST_DIR}/cmake/nsx/nsx_app_bootstrap.cmake)

nsx_bootstrap_app(
    APP_ROOT "${CMAKE_CURRENT_LIST_DIR}"
    BOARD "${NSX_BOARD}"
    MODULES ${NSX_APP_MODULES}
)

# --- Profiler application ---
{% if engine_type == "helia-aot" %}
add_executable(hpx_profiler
    src/main.cc
)

target_include_directories(hpx_profiler PRIVATE
    ${CMAKE_CURRENT_LIST_DIR}/src
)

target_link_libraries(hpx_profiler PRIVATE
    nsx::board
    nsx::runtime_core
    nsx::power
{% if has_full_pmu %}
    nsx::pmu_armv8m
{% endif %}
    {{ aot_cmake_target }}
{% if transport == "usb_cdc" %}
    nsx::usb
{% endif %}
{% if psram_needed %}
    nsx::peripherals
{% endif %}
)
{% if psram_needed %}
# AmbiqSuite PSRAM device driver — not part of a pre-compiled lib
target_sources(hpx_profiler PRIVATE
    ${NSX_ROOT}/modules/nsx-ambiqsuite-r5/sdk/src/am_devices_mspi_psram_aps25616ba_1p2v.c
)
target_include_directories(hpx_profiler PRIVATE
    ${NSX_ROOT}/modules/nsx-ambiqsuite-r5/sdk/devices
)
{% endif %}
{% if transport == "rtt" %}
target_sources(hpx_profiler PRIVATE
    ${CMAKE_CURRENT_LIST_DIR}/src/rtt/SEGGER_RTT.c
)
target_include_directories(hpx_profiler PRIVATE
    ${CMAKE_CURRENT_LIST_DIR}/src/rtt
    ${CMAKE_CURRENT_LIST_DIR}/src/rtt/Config
)
# ConfigUpBuffer(0) cannot change buffer-0's pointer/size (SEGGER design).
# Override the compile-time default so _DoInit() allocates 32 KB.
target_compile_definitions(hpx_profiler PRIVATE BUFFER_SIZE_UP=32768)
{% endif %}
{% else %}
add_executable(hpx_profiler
    src/main.cc
    src/hpx_pmu_profiler.cc
)

target_include_directories(hpx_profiler PRIVATE
    ${CMAKE_CURRENT_LIST_DIR}/src
)

target_link_libraries(hpx_profiler PRIVATE
    nsx::board
    nsx::runtime_core
    nsx::power
{% if has_full_pmu %}
    nsx::pmu_armv8m
{% endif %}
{% if engine_type == "helia-rt" %}
    nsx::helia_rt
{% endif %}
{% if transport == "usb_cdc" %}
    nsx::usb
{% endif %}
{% if psram_needed %}
    nsx::peripherals
{% endif %}
)
{% if psram_needed %}
# AmbiqSuite PSRAM device driver — not part of a pre-compiled lib
target_sources(hpx_profiler PRIVATE
    ${NSX_ROOT}/modules/nsx-ambiqsuite-r5/sdk/src/am_devices_mspi_psram_aps25616ba_1p2v.c
)
target_include_directories(hpx_profiler PRIVATE
    ${NSX_ROOT}/modules/nsx-ambiqsuite-r5/sdk/devices
)
{% endif %}
{% if transport == "rtt" %}
target_sources(hpx_profiler PRIVATE
    ${CMAKE_CURRENT_LIST_DIR}/src/rtt/SEGGER_RTT.c
)
target_include_directories(hpx_profiler PRIVATE
    ${CMAKE_CURRENT_LIST_DIR}/src/rtt
    ${CMAKE_CURRENT_LIST_DIR}/src/rtt/Config
)
target_compile_definitions(hpx_profiler PRIVATE BUFFER_SIZE_UP=32768)
{% endif %}
