nsx_finalize_app(hpx_profiler)

# armclang in C++ mode triggers -Wreserved-user-defined-literal on some
# AmbiqSuite headers (string literal concatenation without a space).
# Suppress it until the SDK headers are fixed upstream.
if(CMAKE_CXX_COMPILER_ID STREQUAL "ARMClang")
    target_compile_options(hpx_profiler PRIVATE
        $<$<COMPILE_LANGUAGE:CXX>:-Wno-reserved-user-defined-literal>
    )
endif()
