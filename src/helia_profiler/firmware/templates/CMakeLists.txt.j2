{# CMakeLists.txt — top-level CMake for the profiler NSX app #}
# Auto-generated by heliaPROFILER — do not edit.
cmake_minimum_required(VERSION 3.24)
project(hpx_profiler LANGUAGES C CXX ASM)

{% set psram_arena_needed = (arena_regions | selectattr("placement", "equalto", "psram") | list | length) > 0 %}
{% set psram_needed = (arena_region == "psram") or (weights_region == "psram") or psram_arena_needed %}
set(NSX_BOARD "{{ board }}" CACHE STRING "Target board")

# Pin the AmbiqSuite BSP library subdir to the board name before nsx-ambiq-bsp
# loads. The board fragment sets this too, but if the BSP module is added first
# it falls back to a bare "evb" default and the prebuilt lib path resolves wrong.
set(NSX_AMBIQ_BSP_LIB_SUBDIR "{{ board }}" CACHE STRING "AmbiqSuite BSP lib subdir")

{% for var_name, var_value in cmake_vars.items() %}
set({{ var_name }} "{{ var_value }}")
{% endfor %}

{% if compiler_launcher %}
# Compiler launcher (e.g. sccache/ccache) — caches object output across builds.
# ASM is included intentionally: the NSX toolchains compile their assembly via
# the C/clang driver, so the launcher wraps it the same way as C/C++.
set(CMAKE_C_COMPILER_LAUNCHER "{{ compiler_launcher }}")
set(CMAKE_CXX_COMPILER_LAUNCHER "{{ compiler_launcher }}")
set(CMAKE_ASM_COMPILER_LAUNCHER "{{ compiler_launcher }}")
{% endif %}

include(${CMAKE_CURRENT_LIST_DIR}/cmake/nsx/modules.cmake)
include(${CMAKE_CURRENT_LIST_DIR}/cmake/nsx/nsx_app_bootstrap.cmake)

nsx_bootstrap_app(
    APP_ROOT "${CMAKE_CURRENT_LIST_DIR}"
    BOARD "${NSX_BOARD}"
    MODULES ${NSX_APP_MODULES}
)

# --- Profiler application ---
{% if engine_type == "helia-aot" %}
add_executable(hpx_profiler
    src/main.cc
)

target_include_directories(hpx_profiler PRIVATE
    ${CMAKE_CURRENT_LIST_DIR}/src
)

target_link_libraries(hpx_profiler PRIVATE
    nsx::board
    nsx::runtime_core
    nsx::cmsis_core
{% if power_sync_enabled %}
    nsx::gpio
{% endif %}
{% if has_armv8m_pmu %}
    nsx::pmu_armv8m
{% endif %}
    {{ aot_cmake_target }}
{% if transport == "usb_cdc" %}
    nsx::usb
{% endif %}
{% if psram_needed %}
    nsx::psram
{% endif %}
)
{% if transport == "rtt" %}
target_sources(hpx_profiler PRIVATE
    ${CMAKE_CURRENT_LIST_DIR}/src/rtt/SEGGER_RTT.c
)
target_include_directories(hpx_profiler PRIVATE
    ${CMAKE_CURRENT_LIST_DIR}/src/rtt
    ${CMAKE_CURRENT_LIST_DIR}/src/rtt/Config
)
# ConfigUpBuffer(0) cannot change buffer-0's pointer/size (SEGGER design).
# Override the compile-time default so _DoInit() allocates the requested
# transport buffer size.
target_compile_definitions(hpx_profiler PRIVATE BUFFER_SIZE_UP={{ rtt_buffer_size_up }})
{% endif %}
{% if power_binary_enabled %}

