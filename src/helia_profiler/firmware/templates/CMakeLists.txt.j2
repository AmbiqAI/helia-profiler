# armclang/ATFE clang++ in C++ mode trigger -Wreserved-user-defined-literal on
# some AmbiqSuite headers (string literal concatenation without a space).
# Suppress it until the SDK headers are fixed upstream.
if(CMAKE_CXX_COMPILER_ID STREQUAL "ARMClang" OR CMAKE_CXX_COMPILER_ID STREQUAL "Clang")
    target_compile_options(hpx_profiler PRIVATE
        $<$<COMPILE_LANGUAGE:CXX>:-Wno-reserved-user-defined-literal>
    )
{% if power_binary_enabled %}
    target_compile_options(hpx_profiler_power PRIVATE
        $<$<COMPILE_LANGUAGE:CXX>:-Wno-reserved-user-defined-literal>
    )
{% endif %}
endif()

# ATFE clang++ does not define __GNUC_STDC_INLINE__ in C++ mode, but Ambiq's
# HAL uses that macro to select the GNU-compatible declaration path for some
# APIs. Define it for ATFE C++ builds so power-sync GPIO support compiles.
if(CMAKE_CXX_COMPILER_ID STREQUAL "Clang")
    target_compile_definitions(hpx_profiler PRIVATE
        $<$<COMPILE_LANGUAGE:CXX>:__GNUC_STDC_INLINE__=1>
    )
{% if power_binary_enabled %}
    target_compile_definitions(hpx_profiler_power PRIVATE
        $<$<COMPILE_LANGUAGE:CXX>:__GNUC_STDC_INLINE__=1>
    )
{% endif %}
endif()

