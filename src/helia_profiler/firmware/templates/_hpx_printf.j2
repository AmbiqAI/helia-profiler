{# _hpx_printf.j2 — transport-aware hpx_printf + RTT drain helper.

   Variables:
     transport         : "usb_cdc" | "rtt" | other (stdio fallback)
     printf_linkage    : "" (extern, e.g. main.cc) or "static " (internal, main_aot.cc)
     power_only        : true for the dedicated power binary (no transport at all)
#}
// ---------------------------------------------------------------------------
// hpx_printf — transport-aware printf used by all profiler output
// ---------------------------------------------------------------------------
{% set _linkage = printf_linkage | default("") %}
{% if power_only | default(false) %}
// power_only: no transport is ever initialized on this binary (see the
// design note in AGENTS.md / WP1) -- UART leaves UART0-3 powered (+17%
// current on an AP510 EVB), SWO holds PD_DBG (+33%), USB PHY (+60%).  The
// dedicated power binary must be clean by construction, so hpx_printf
// compiles away to nothing rather than merely disabling a transport at
// runtime (which still leaves pad/pinmux/clock residue).  The host observes
// completion via the GPIO gate, not via any transport.
{{ _linkage }}void hpx_printf(const char *, ...) {}
{% elif transport == "usb_cdc" %}
static uint8_t usb_tx_buf[4096];
static uint8_t usb_rx_buf[NSX_USB_MIN_CDC_RX_BUFSIZE];

{% if usb_serial_marker | default(false) %}
// Unique USB identity stamped by hpx at firmware-generation time so the host
// can match this exact board's CDC device (pyserial serial_number) even when
// several Ambiq boards are attached.  Derived from the J-Link probe serial.
static const nsx_usb_device_desc_t g_hpx_usb_desc = {
    .product = "{{ usb_serial_product | default("NSX HPX Profiler") }}",
    .serial  = "{{ usb_serial_marker }}",
};
{% endif %}

static nsx_usb_config_t g_usb_cfg = {
    .tx_buffer     = usb_tx_buf,
    .tx_buffer_len = sizeof(usb_tx_buf),
    .rx_buffer     = usb_rx_buf,
    .rx_buffer_len = sizeof(usb_rx_buf),
{% if usb_serial_marker | default(false) %}
    .device_desc   = &g_hpx_usb_desc,
{% endif %}
};

{{ _linkage }}void hpx_printf(const char *fmt, ...) {
    static char line_buf[512];
    va_list ap;
    va_start(ap, fmt);
    int n = vsnprintf(line_buf, sizeof(line_buf), fmt, ap);
    va_end(ap);
    if (n > 0) {
        uint32_t sent = 0;
        nsx_usb_send(&g_usb_cfg, line_buf, (uint32_t)n, &sent);
    }
}
{% elif transport == "rtt" %}
// Per-line timeout for lossless RTT writes (CSV rows + HPX_END).  Generous: the
// host normally drains within milliseconds; this only caps a truly dead host so
// the firmware cannot wedge forever.
#ifndef HPX_RTT_LOSSLESS_TIMEOUT_MS
#define HPX_RTT_LOSSLESS_TIMEOUT_MS 2000U
#endif

// Shortened per-line timeout used for writes issued AFTER the gated
// power/clean window has completed (see hpx_rtt_shorten_lossless_timeout).
// A power-only capture never has a host reading RTT during/after the gated
// window — the host is watching the GPIO gate via a separate instrument, not
// draining the ring buffer — so hitting a slow host is actually the *expected*
// steady state there, not a rare dead-host edge case.  Spinning the full 2s
// budget per queued line (found 2026-07-05: forensics showed the firmware
// parked in hpx_rtt_write_lossless for the entire post-window CSV dump with
// no host attached) turns a handful of trailing lines into many seconds of
// silent, pointless spin.  100ms is enough for a host that *is* still
// attached (e.g. a PMU-then-power run in the same session) to keep draining
// promptly, without paying the full dead-host budget by default.
#ifndef HPX_RTT_LOSSLESS_TIMEOUT_POST_WINDOW_MS
#define HPX_RTT_LOSSLESS_TIMEOUT_POST_WINDOW_MS 100U
#endif

// Runtime-adjustable copy of the lossless timeout so a single build can use
// the generous default normally and the short post-window budget only after
// a gated power window has actually run (see hpx_rtt_shorten_lossless_timeout).
static volatile uint32_t g_hpx_rtt_lossless_timeout_ms = HPX_RTT_LOSSLESS_TIMEOUT_MS;

// When true, hpx_printf writes losslessly (waits for ring-buffer space) instead
// of dropping on overflow.  Set around CSV dumps / HPX_END; cleared during the
// timed inference window where droppable heartbeats must never stall the CPU.
static volatile bool g_hpx_rtt_lossless = false;

// Refresh ONLY the SEGGER RTT control block in the D-cache so the CPU observes
// the host-advanced up-buffer RdOff.  The control block and RTT ring buffers
// live in non-cacheable TCM, so on Apollo510 this is effectively a no-op (the
// region has no D-cache lines), yet it stays correct should the block ever be
// relocated to cacheable memory.  It replaces the previous WHOLE-cache
// invalidate (am_hal_cachectrl_dcache_invalidate(NULL, false)), which also
// discarded not-yet-written-back lines of a tensor arena placed in cacheable
// SSRAM/PSRAM -- silently zeroing the allocator's persistent tensors so
// interpreter.input()/output() returned NULL and inference hung.  TCM arenas
// were immune (non-cacheable), which is why only Apollo510 SRAM/PSRAM broke.
static inline void hpx_rtt_invalidate_cb(void) {
{% if (has_dcache | default(false)) %}
#if defined(__DCACHE_PRESENT) && (__DCACHE_PRESENT == 1U)
    SCB_InvalidateDCache_by_Addr((volatile void *)&_SEGGER_RTT,
                                 (int32_t)sizeof(_SEGGER_RTT));
#endif
{% else %}
    // Cortex-M4 (Apollo3/Apollo4) has no CPU D-cache; nothing to invalidate.
{% endif %}
}

// Lossless RTT up-buffer write.
//
// The up-buffer stays in NO_BLOCK_TRIM at all times; we do the "wait for space"
// ourselves rather than using SEGGER's BLOCK_IF_FIFO_FULL.  SEGGER's blocking
// write spins on the up-buffer RdOff, which the host (J-Link) advances by
// writing SRAM over SWD.  On a cached M55 the CPU reads that RdOff through stale
// D-cache and never observes the drain, so the blocking write deadlocks once the
// buffer fills.  Here we INVALIDATE before each space check so we see the host's
// RdOff coherently, then issue the (now guaranteed to fit) write and CLEAN so
// the host sees our bytes.  CSV/HPX_END phase only — never inside a timed window.
static void hpx_rtt_write_lossless(const char *buf, unsigned len) {
    const uint32_t spins_per_ms = SystemCoreClock / 2000U;
    uint32_t budget = g_hpx_rtt_lossless_timeout_ms * spins_per_ms;
    for (;;) {
        hpx_rtt_invalidate_cb();  // refresh host-advanced RdOff (CB only, not the arena)
        if (SEGGER_RTT_GetAvailWriteSpace(0) >= len) {
            break;
        }
        if (budget == 0U) {
            break;  // host appears dead — fall through; NO_BLOCK_TRIM will trim
        }
        for (volatile uint32_t s = 0; s < spins_per_ms; ++s) { __NOP(); }
        budget = (budget > spins_per_ms) ? budget - spins_per_ms : 0U;
    }
    SEGGER_RTT_Write(0, buf, len);
    HPX_CLEAN_DCACHE();  // publish bytes to SRAM so the host/J-Link can read them
}

{{ _linkage }}void hpx_printf(const char *fmt, ...) {
    static char line_buf[512];
    va_list ap;
    va_start(ap, fmt);
    int n = vsnprintf(line_buf, sizeof(line_buf), fmt, ap);
    va_end(ap);
    if (n > 0) {
        if (g_hpx_rtt_lossless) {
            hpx_rtt_write_lossless(line_buf, (unsigned)n);
        } else {
            // Timed window: droppable, never stalls (protects PMU/cycle counts).
            SEGGER_RTT_Write(0, line_buf, (unsigned)n);
            HPX_CLEAN_DCACHE();
        }
    }
}

// Wait until the RTT up-buffer has drained (host has read it) or a soft timeout
// elapses.  Belt-and-braces after HPX_END.  HasDataUp compares WrOff against the
// host-advanced RdOff, so invalidate each poll to observe the drain coherently
// on cached targets.
static void hpx_rtt_drain(uint32_t timeout_ms) {
    const uint32_t spins_per_ms = SystemCoreClock / 2000U; // conservative
    uint32_t total = timeout_ms * spins_per_ms;
    hpx_rtt_invalidate_cb();
    while (SEGGER_RTT_HasDataUp(0) && total > 0U) {
        for (volatile uint32_t s = 0; s < spins_per_ms; ++s) { __NOP(); }
        if (total > spins_per_ms) total -= spins_per_ms; else total = 0;
        hpx_rtt_invalidate_cb();
    }
}

// Lossless-write mode toggle for the RTT up-buffer (see hpx_rtt_write_lossless).
//
// The buffer stays NO_BLOCK_TRIM at all times so a write that happens *during* a
// timed interpreter.Invoke()/model_run() (e.g. an in-flight heartbeat) can never
// stall the CPU and skew the cycle/PMU counts — those writes are intentionally
// droppable.  CSV dumps and the HPX_END sentinel happen *outside* the timed
// window where losing data is fatal to the host parser, so we flip the lossless
// flag for those.  Correctness is independent of BUFFER_SIZE_UP and model size;
// the buffer size is a pure throughput/latency knob.
static void hpx_rtt_set_blocking(void) {
    g_hpx_rtt_lossless = true;
}
static void hpx_rtt_set_nonblocking(void) {
    g_hpx_rtt_lossless = false;
}

// Call once, right after a gated power/clean window completes (see
// main.cc.j2), before any subsequent hpx_rtt_set_blocking()/hpx_printf() call.
// See HPX_RTT_LOSSLESS_TIMEOUT_POST_WINDOW_MS above for why.
static void hpx_rtt_shorten_lossless_timeout(void) {
    g_hpx_rtt_lossless_timeout_ms = HPX_RTT_LOSSLESS_TIMEOUT_POST_WINDOW_MS;
}
{% elif transport == "swo" %}
{{ _linkage }}void hpx_printf(const char *fmt, ...) {
    static char line_buf[512];
    va_list ap;
    va_start(ap, fmt);
    int n = vsnprintf(line_buf, sizeof(line_buf), fmt, ap);
    va_end(ap);
    if (n > 0) {
        nsx_printf("%s", line_buf);
    }
}
{% else %}
{{ _linkage }}void hpx_printf(const char *fmt, ...) {
    static char line_buf[512];
    va_list ap;
    va_start(ap, fmt);
    int n = vsnprintf(line_buf, sizeof(line_buf), fmt, ap);
    va_end(ap);
    if (n > 0) {
        nsx_printf("%s", line_buf);
    }
}
{% endif %}

// ---------------------------------------------------------------------------
// hpx_park — terminal halt used by the HPX_END happy path and every error exit.
//
// On RTT the control block + ring buffers live in non-cached TCM on the
// cache-coherent Cortex-M55 parts, and the J-Link can only reach TCM while the
// core clock is running.  Once the core enters __WFI() the host can no longer
// drain the ring, so any bytes still queued — crucially a final HPX_ERROR=...
// line on a failure path — would be lost.  We therefore switch to lossless
// mode, publish, and drain the ring while the core is still spinning, then
// park.  Non-RTT transports (SWO/USB/stdio) send synchronously, so they simply
// park.  This keeps the failure diagnostics observable regardless of toolchain.
// ---------------------------------------------------------------------------
{% if transport == "rtt" and not power_only | default(false) %}
#ifndef HPX_RTT_FAIL_DRAIN_MS
// Generous: if no host has attached yet, hpx_rtt_drain() spins the full window
// (RdOff never advances), giving a late-attaching host time to read the buffer.
#define HPX_RTT_FAIL_DRAIN_MS 3000U
#endif
{% endif %}

{{ _linkage }}void hpx_park(void) {
{% if power_only | default(false) %}
    // power_only: no transport, so no ring buffer to drain -- just halt.  The
    // host observes completion via the GPIO gate falling, not via RTT/SWO/USB.
{% elif transport == "rtt" %}
    hpx_rtt_set_blocking();
    HPX_CLEAN_DCACHE();
    hpx_rtt_drain(HPX_RTT_FAIL_DRAIN_MS);
{% endif %}
    for (;;) { __WFI(); }
}
