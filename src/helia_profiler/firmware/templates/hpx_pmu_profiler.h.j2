{# hpx_pmu_profiler.h — PMU profiler header #}
#ifndef HPX_PMU_PROFILER_H
#define HPX_PMU_PROFILER_H

#include "tensorflow/lite/micro/micro_profiler_interface.h"

// Pre-include arm_mve.h in C++ context so that ns_core.h's extern "C"
// re-inclusion is a harmless no-op (avoids overload conflicts with GCC 14).
#if defined(__ARM_FEATURE_MVE)
#include <arm_mve.h>
#endif
#include "ns_pmu_utils.h"

class HpxPmuProfiler : public tflite::MicroProfilerInterface {
 public:
    static constexpr int kMaxLayers = 512;
    static constexpr int kMaxEvents = 4;

    HpxPmuProfiler() = default;
    ~HpxPmuProfiler() override = default;

    /// Legacy preset-based init (backward compatibility).
    void Init(ns_pmu_preset_e preset = NS_PMU_PRESET_ML_DEFAULT);

    /// Custom init — configure explicit PMU event IDs.
    /// @param event_ids  Array of ARM PMU event IDs (e.g. 0x0011 for CPU_CYCLES).
    /// @param num_events Number of events (1..kMaxEvents).
    void InitCustom(const uint32_t event_ids[], int num_events);

    uint32_t BeginEvent(const char* tag) override;
    void EndEvent(uint32_t event_handle) override;

    void ClearEvents();
    void PrintCsv() const;
    int num_events() const { return num_events_; }
    int num_counters() const { return num_counters_; }

    /// Configure heartbeat emission cadence.
    /// @param every_cyc   DWT CYCCNT delta between heartbeats; 0 disables.
    /// @param every_n_ops Ops between heartbeats; 0 disables.
    /// Either trigger fires independently; if both are 0 no intra-inference
    /// heartbeats are emitted (phase heartbeats from main are unaffected).
    void SetHeartbeat(uint32_t every_cyc, int every_n_ops);

    /// Set the pass/iteration labels embedded in heartbeat lines.
    /// Called by main.cc at the start of each iteration.
    void SetIterationContext(int pass_idx, int iter_idx);

 private:
    struct LayerRecord {
        const char* tag;
        uint32_t counters[kMaxEvents];
        bool overflow;  // true if any PMU counter overflowed during this layer
    };
    ns_pmu_config_t pmu_cfg_ = {};
    LayerRecord layers_[kMaxLayers] = {};
    int num_events_ = 0;
    int num_counters_ = 0;  // actual number of configured PMU counters
    bool initialized_ = false;

    // Heartbeat state (not in hot PMU path — emission happens between ops)
    uint32_t hb_every_cyc_ = 0;
    int hb_every_n_ops_ = 0;
    uint32_t hb_last_cyc_ = 0;
    int hb_ops_since_ = 0;
    int hb_pass_ = 0;
    int hb_iter_ = 0;

    void MaybeEmitHeartbeat();
};

#endif  // HPX_PMU_PROFILER_H
