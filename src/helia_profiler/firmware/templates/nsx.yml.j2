{# nsx.yml — NSX project manifest for the profiler app #}
schema_version: 1
project:
  name: hpx_profiler
target:
  board: {{ board }}
  soc: {{ soc }}
toolchain: {{ toolchain }}
channel: stable
profile: {{ board }}_minimal
profile_status: active
modules:
{% for m in modules %}
- name: {{ m.name }}
{% if m.local %}
  local: true
{% else %}
  revision: main
  project: {{ m.name }}
{% endif %}
{% endfor %}
features: {}
module_registry:
  projects: {}
  modules: {}
