{# nsx.yml — NSX project manifest for the profiler app #}
schema_version: 1
project:
  name: hpx_profiler
target:
  board: {{ board }}
  soc: {{ soc }}
toolchain: {{ toolchain }}
channel: {{ channel }}
profile: {{ board }}_minimal
profile_status: active
modules:
{% for m in modules %}
- name: {{ m.name }}
{% if m.local %}
  local: true
{% elif m.ref is defined and m.ref %}
  project: {{ m.project }}
  ref: {{ m.ref }}
{% elif m.version is defined and m.version %}
  project: {{ m.project }}
  version: "{{ m.version }}"
{% else %}
  project: {{ m.project }}
{% endif %}
{% endfor %}
features: {}
{% if module_registry_yaml %}
{{ module_registry_yaml }}
{%- endif %}
