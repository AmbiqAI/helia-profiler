{# nsx.yml — NSX project manifest for the profiler app #}
schema_version: 1
project:
  name: hpx_profiler
target:
  board: {{ board }}
  soc: {{ soc }}
toolchain: {{ toolchain }}
channel: {{ channel }}
profile: {{ board }}_minimal
profile_status: active
modules:
{% for m in modules %}
- name: {{ m.name }}
{% if m.local %}
  local: true
{% elif m.get("ref") %}
  project: {{ m.name }}
  ref: {{ m["ref"] }}
{% elif m.get("version") %}
  project: {{ m.name }}
  version: "{{ m["version"] }}"
{% else %}
  project: {{ m.name }}
{% endif %}
{% endfor %}
features: {}
