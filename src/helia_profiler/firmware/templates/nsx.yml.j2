{# nsx.yml — NSX project manifest for the profiler app #}
schema_version: 2
project:
  name: hpx_profiler
targets:
  default: {{ board }}
  supported:
    - {{ board }}
toolchain: {{ toolchain }}
channel: {{ channel }}
modules:
{% for m in modules %}
- name: {{ m.name }}
{% if m.local %}
  source:
    vendored: true
{% elif m.ref is defined and m.ref %}
  project: {{ m.project }}
  ref: {{ m.ref }}
{% elif m.version is defined and m.version %}
  project: {{ m.project }}
  version: "{{ m.version }}"
{% else %}
  project: {{ m.project }}
{% endif %}
{% endfor %}
features: {}
{% if module_registry_yaml %}
{{ module_registry_yaml }}
{%- endif %}
