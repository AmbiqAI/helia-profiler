{# hpx_pmu_profiler.cc — PMU profiler implementation #}
#include "hpx_pmu_profiler.h"

// arm_mve.h already pre-included via hpx_pmu_profiler.h
#include "ns_ambiqsuite_harness.h"
#include "ns_pmu_map.h"

void HpxPmuProfiler::Init(ns_pmu_preset_e preset) {
    ns_pmu_reset_config(&pmu_cfg_);
    pmu_cfg_.api = &ns_pmu_V1_0_0;
    ns_pmu_apply_preset(&pmu_cfg_, preset);
    ns_pmu_init(&pmu_cfg_);
    num_events_ = 0;
    // Count how many events the preset configured
    num_counters_ = 0;
    for (int i = 0; i < kMaxEvents; i++) {
        if (pmu_cfg_.events[i].enabled) num_counters_++;
    }
    initialized_ = true;
}

void HpxPmuProfiler::InitCustom(const uint32_t event_ids[], int num_events) {
    ns_pmu_reset_config(&pmu_cfg_);
    pmu_cfg_.api = &ns_pmu_V1_0_0;
    int n = (num_events > kMaxEvents) ? kMaxEvents : num_events;
    for (int i = 0; i < n; i++) {
        ns_pmu_event_create(&pmu_cfg_.events[i], event_ids[i],
                            NS_PMU_EVENT_COUNTER_SIZE_32);
    }
    ns_pmu_init(&pmu_cfg_);
    num_events_ = 0;
    num_counters_ = n;
    initialized_ = true;
}

uint32_t HpxPmuProfiler::BeginEvent(const char* tag) {
    if (!initialized_ || num_events_ >= kMaxLayers) return 0;
    int idx = num_events_++;
    layers_[idx].tag = tag;
    layers_[idx].overflow = false;
    uint32_t saved_cyccnt = DWT->CYCCNT;
    ns_pmu_reset_counters();
    DWT->CYCCNT = saved_cyccnt;
    // Clear any prior overflow flags so we detect overflow for this layer only
#if (__CORTEX_M >= 55U)
    ARM_PMU_Set_CNTR_OVS(0xFFFFFFFFU);
#endif
    return static_cast<uint32_t>(idx);
}

void HpxPmuProfiler::EndEvent(uint32_t event_handle) {
    if (!initialized_ ||
        event_handle >= static_cast<uint32_t>(num_events_)) return;
    uint32_t saved_cyccnt = DWT->CYCCNT;
    ns_pmu_get_counters(&pmu_cfg_);
    DWT->CYCCNT = saved_cyccnt;
    LayerRecord& rec = layers_[event_handle];
    for (int i = 0; i < num_counters_; i++) {
        rec.counters[i] = pmu_cfg_.counter[i].counterValue;
    }
    // Detect counter overflow via the PMU overflow status register
#if (__CORTEX_M >= 55U)
    uint32_t ovs = ARM_PMU_Get_CNTR_OVS();
    rec.overflow = (ovs != 0);
    if (ovs) ARM_PMU_Set_CNTR_OVS(ovs);
#else
    rec.overflow = false;
#endif
}

void HpxPmuProfiler::ClearEvents() { num_events_ = 0; }

void HpxPmuProfiler::PrintCsv() const {
    if (!initialized_ || num_events_ == 0) return;
    ns_printf("\"Layer\",\"Op\"");
    for (int e = 0; e < num_counters_; e++) {
        if (!pmu_cfg_.events[e].enabled) break;
        uint32_t map_idx = pmu_cfg_.counter[e].mapIndex;
        if (map_idx < NS_PMU_MAP_SIZE)
            ns_printf(",\"%s\"", ns_pmu_map[map_idx].regname);
        else
            ns_printf(",\"event_%d\"", e);
    }
    ns_printf(",\"overflow\"\n");
    for (int i = 0; i < num_events_; i++) {
        const LayerRecord& rec = layers_[i];
        ns_printf("%d,%s", i, rec.tag ? rec.tag : "?");
        for (int e = 0; e < num_counters_; e++) {
            if (!pmu_cfg_.events[e].enabled) break;
            ns_printf(",%lu", (unsigned long)rec.counters[e]);
        }
        ns_printf(",%d\n", rec.overflow ? 1 : 0);
    }
}
