{# main.cc — heliaPROFILER firmware entry point #}
/**
 * @file main.cc
 * @brief heliaPROFILER firmware — auto-generated, do not edit.
 *
 * Runs inference with per-layer PMU profiling and emits CSV results
 * over SWO/UART for the host-side capture stage to parse.
 *
 * When external power measurement is enabled, a GPIO sync pin is toggled
 * HIGH during inference and LOW otherwise so the host instrument can
 * identify the measurement window.
 */

#include <cstdint>
#include <cstdio>
#include <cstring>

#include "{{ engine_header }}"
#include "tensorflow/lite/micro/micro_mutable_op_resolver.h"
#include "tensorflow/lite/micro/system_setup.h"
#include "tensorflow/lite/micro/tflite_bridge/micro_error_reporter.h"
#include "tensorflow/lite/schema/schema_generated.h"

#include "hpx_pmu_profiler.h"

// arm_mve.h pre-included via hpx_pmu_profiler.h
#include "ns_core.h"
#include "ns_ambiqsuite_harness.h"
#include "nsx_mem.h"
#include "nsx_system.h"
#include "am_hal_gpio.h"

// DWT cycle counter
static inline void dwt_init(void) {
    CoreDebug->DEMCR |= CoreDebug_DEMCR_TRCENA_Msk;
    DWT->CYCCNT = 0;
    DWT->CTRL |= DWT_CTRL_CYCCNTENA_Msk;
}

// --- GPIO sync for external power measurement ---
static constexpr bool kPowerSyncEnabled = {{ power_sync_enabled | lower }};
static constexpr uint32_t kSyncGpioPin = {{ sync_gpio_pin }};

static inline void sync_gpio_init(void) {
    if constexpr (kPowerSyncEnabled) {
        am_hal_gpio_pinconfig(kSyncGpioPin, am_hal_gpio_pincfg_output);
        am_hal_gpio_output_clear(kSyncGpioPin);
    }
}

static inline void sync_gpio_high(void) {
    if constexpr (kPowerSyncEnabled) {
        am_hal_gpio_output_set(kSyncGpioPin);
    }
}

static inline void sync_gpio_low(void) {
    if constexpr (kPowerSyncEnabled) {
        am_hal_gpio_output_clear(kSyncGpioPin);
    }
}

// Model data (xxd-style include)
#include "model_data.h"

static constexpr int kArenaSize = {{ arena_size }};
static constexpr int kMaxOps = 128;

NSX_MEM_FAST_BSS alignas(16) static uint8_t g_arena[kArenaSize];
static HpxPmuProfiler g_profiler;

// Register all common TFLM builtin ops for broad model compatibility.
static tflite::MicroMutableOpResolver<kMaxOps> &get_resolver() {
    static tflite::MicroMutableOpResolver<kMaxOps> r;
    static bool init = false;
    if (!init) {
        r.AddAbs();           r.AddAdd();
        r.AddAddN();          r.AddArgMax();
        r.AddArgMin();        r.AddAveragePool2D();
        r.AddBatchMatMul();   r.AddBatchToSpaceNd();
        r.AddBroadcastArgs(); r.AddBroadcastTo();
        r.AddCast();          r.AddCeil();
        r.AddConcatenation(); r.AddConv2D();
        r.AddCumSum();        r.AddDepthToSpace();
        r.AddDepthwiseConv2D(); r.AddDequantize();
        r.AddDiv();           r.AddElu();
        r.AddEmbeddingLookup(); r.AddEqual();
        r.AddExp();           r.AddExpandDims();
        r.AddFill();          r.AddFloor();
        r.AddFloorDiv();      r.AddFloorMod();
        r.AddFullyConnected(); r.AddGather();
        r.AddGatherNd();      r.AddGreater();
        r.AddGreaterEqual();  r.AddHardSwish();
        r.AddL2Normalization(); r.AddL2Pool2D();
        r.AddLeakyRelu();     r.AddLess();
        r.AddLessEqual();     r.AddLog();
        r.AddLogSoftmax();    r.AddLogicalAnd();
        r.AddLogicalNot();    r.AddLogicalOr();
        r.AddLogistic();      r.AddMaxPool2D();
        r.AddMaximum();       r.AddMean();
        r.AddMinimum();       r.AddMirrorPad();
        r.AddMul();           r.AddNeg();
        r.AddNotEqual();      r.AddPack();
        r.AddPad();           r.AddPadV2();
        r.AddPrelu();         r.AddQuantize();
        r.AddReduceMax();     r.AddRelu();
        r.AddRelu6();         r.AddReshape();
        r.AddResizeBilinear(); r.AddResizeNearestNeighbor();
        r.AddRound();         r.AddRsqrt();
        r.AddSelectV2();      r.AddShape();
        r.AddSlice();         r.AddSoftmax();
        r.AddSpaceToBatchNd(); r.AddSpaceToDepth();
        r.AddSplit();         r.AddSplitV();
        r.AddSqrt();          r.AddSquare();
        r.AddSquaredDifference(); r.AddSqueeze();
        r.AddStridedSlice();  r.AddSub();
        r.AddSum();           r.AddSvdf();
        r.AddTanh();          r.AddTranspose();
        r.AddTransposeConv(); r.AddUnidirectionalSequenceLSTM();
        r.AddUnpack();        r.AddZerosLike();
        init = true;
    }
    return r;
}

int main(void) {
    nsx_system_config_t sys_cfg = nsx_system_development;
    NS_TRY(nsx_system_init(&sys_cfg), "System init failed\n");
    dwt_init();
    sync_gpio_init();

    // Delay to allow the host SWO viewer to attach after reset.
    // The board boots immediately after flash/reset; without this pause
    // the profiler output would be emitted before the viewer connects.
    am_util_delay_ms(5000);

    ns_printf("\n--- HPX_START ---\n");
    ns_printf("HPX_MODEL_SIZE=%u\n", model_data_len);
    ns_printf("HPX_ARENA_SIZE=%d\n", kArenaSize);
    ns_printf("HPX_ITERATIONS={{ iterations }}\n");
    ns_printf("HPX_WARMUP={{ warmup }}\n");
    ns_printf("HPX_NUM_PRESETS=%d\n", {{ pmu_passes | length }});
    ns_printf("HPX_PRESETS={{ pmu_pass_names | join(',') }}\n");
    ns_printf("HPX_POWER_SYNC=%s\n", kPowerSyncEnabled ? "gpio" : "none");
    if constexpr (kPowerSyncEnabled) {
        ns_printf("HPX_SYNC_GPIO=%lu\n", (unsigned long)kSyncGpioPin);
    }

    tflite::InitializeTarget();

    const tflite::Model *model = tflite::GetModel(model_data);
    if (model->version() != TFLITE_SCHEMA_VERSION) {
        ns_printf("HPX_ERROR=schema_mismatch:%lu_vs_%d\n",
                  model->version(), TFLITE_SCHEMA_VERSION);
        while (1) {}
    }

    // Use the first pass to allocate (all passes use the same model/arena)
{% if pmu_passes[0].custom %}
    {
        static const uint32_t _init_ids[] = { {{ pmu_passes[0].event_ids | join(', ') }} };
        g_profiler.InitCustom(_init_ids, {{ pmu_passes[0].num_counters }});
    }
{% else %}
    g_profiler.Init({{ pmu_passes[0].c_enum }});
{% endif %}

    auto &resolver = get_resolver();
    tflite::MicroInterpreter interpreter(model, resolver, g_arena, kArenaSize,
                                         nullptr, &g_profiler);
    if (interpreter.AllocateTensors() != kTfLiteOk) {
        ns_printf("HPX_ERROR=alloc_tensors_failed\n");
        while (1) {}
    }

    // --- Memory usage metadata ---
    TfLiteTensor *input = interpreter.input(0);
    TfLiteTensor *output = interpreter.output(0);
    ns_printf("HPX_INPUT_SIZE=%d\n", (int)input->bytes);
    ns_printf("HPX_OUTPUT_SIZE=%d\n", (int)output->bytes);
    ns_printf("HPX_ALLOCATED_ARENA=%lu\n", (unsigned long)interpreter.arena_used_bytes());
    ns_printf("HPX_NUM_TENSORS=%d\n", (int)model->subgraphs()->Get(0)->tensors()->size());
    ns_printf("HPX_NUM_INPUTS=%d\n", (int)interpreter.inputs_size());
    ns_printf("HPX_NUM_OUTPUTS=%d\n", (int)interpreter.outputs_size());

    // --- Multi-pass PMU profiling ---
    // Each pass configures a specific set of PMU counters.  When the user
    // requests more counters than fit in a single pass (4 with 32-bit
    // chaining), the profiler runs multiple passes and the host merges
    // the results.  Warmup iterations are repeated per-pass to ensure
    // stable cache / pipeline state.
{% for pass in pmu_passes %}
    ns_printf("\n--- HPX_PRESET {{ pass.name }} ---\n");
{% if pass.custom %}
    {
        static const uint32_t _pass{{ loop.index0 }}_ids[] = { {{ pass.event_ids | join(', ') }} };
        g_profiler.InitCustom(_pass{{ loop.index0 }}_ids, {{ pass.num_counters }});
    }
{% else %}
    g_profiler.Init({{ pass.c_enum }});
{% endif %}

    // Warmup for this pass (profiler disabled, no GPIO sync)
    for (int w = 0; w < {{ warmup }}; w++) {
        memset(input->data.raw, 0, input->bytes);
        interpreter.Invoke();
    }

    // Profiled iterations — GPIO sync brackets each inference
    for (int iter = 0; iter < {{ iterations }}; iter++) {
        memset(input->data.raw, 0, input->bytes);
        g_profiler.ClearEvents();

        sync_gpio_high();
        interpreter.Invoke();
        sync_gpio_low();

        ns_printf("\n--- HPX_ITER %d ---\n", iter);
        g_profiler.PrintCsv();
    }
{% endfor %}

    ns_printf("\n--- HPX_END ---\n");
    while (1) {}
    return 0;
}
