{# main.cc — heliaPROFILER firmware entry point #}
/**
 * @file main.cc
 * @brief heliaPROFILER firmware — auto-generated, do not edit.
 *
 * Runs inference with per-layer PMU profiling and emits CSV results
 * over {{ transport | upper }} for the host-side capture stage to parse.
 *
 * When external power measurement is enabled, a GPIO sync pin is toggled
 * HIGH during inference and LOW otherwise so the host instrument can
 * identify the measurement window.
 */

#include <cstdint>
#include <cstdio>
#include <cstdarg>
#include <cstring>

// Pre-include arm_mve.h in C++ context BEFORE any extern "C" headers
// (nsx_core.h, TFLM) to avoid GCC 14 overload conflicts.
#if defined(__ARM_FEATURE_MVE)
#include <arm_mve.h>
#endif
{% if not has_armv8m_pmu %}
#include <cerrno>
#include <sys/types.h>
{% endif %}

#include "{{ engine_header }}"
#if {{ resource_variable_count }} > 0
#include "tensorflow/lite/micro/micro_allocator.h"
#include "tensorflow/lite/micro/micro_resource_variable.h"
#endif
#include "tensorflow/lite/micro/micro_mutable_op_resolver.h"
#include "tensorflow/lite/micro/system_setup.h"
#include "tensorflow/lite/micro/tflite_bridge/micro_error_reporter.h"
#include "tensorflow/lite/schema/schema_generated.h"
#include "tensorflow/compiler/mlir/lite/schema/schema_utils.h"

#include "hpx_pmu_profiler.h"
{% include "_system_includes.j2" %}

{% include "_cache_shims.j2" %}

// --- Boot-time host-attach delays (microseconds) ---
// These are the few unavoidable firmware-side waits where the host has no
// observable signal to poll: the host SWO/ITM viewer needs time to attach
// after reset, and USB CDC needs a brief settle after the host asserts DTR.
// Keep them named here so they stay discoverable and do not accrete as bare
// magic numbers throughout main().  The host side polls wherever it can
// (see capture/readiness.py); these cover only the genuinely-blind windows.
#define HPX_SWO_ATTACH_DELAY_US   (500U * 1000U)  // host SWO viewer attach grace
#define HPX_USB_POLL_DELAY_US     (10U * 1000U)   // re-poll cadence while waiting for DTR
#define HPX_USB_SETTLE_DELAY_US   (200U * 1000U)  // settle after host asserts DTR
#define HPX_RTT_HOST_READY_TIMEOUT_MS 15000U

{% if not has_armv8m_pmu %}
extern "C" __attribute__((weak)) void _exit(int status) {
    (void)status;
    while (1) { __WFI(); }
}

extern "C" __attribute__((weak)) caddr_t _sbrk(int incr) {
    (void)incr;
    errno = ENOMEM;
    return (caddr_t)-1;
}
{% endif %}

{% include "_dwt_init.j2" %}

{% include "_gpio_sync.j2" %}

{% if transport == "usb_cdc" %}
{% include "_usb_timer.j2" %}
{% endif %}


{% set psram_needed = (arena_region == "psram") or (weights_region == "psram") %}
{% if psram_needed %}
#include "nsx_psram.h"
{% endif %}

{% if weights_region == "psram" %}
// PSRAM model loading — model data is written by J-Link at runtime
static const unsigned char *model_data = nullptr;
static unsigned int model_data_len = {{ model_size }};
{% else %}
// Model data (xxd-style include)
#include "model_data.h"
{% endif %}

{% include "_hpx_printf.j2" %}

static constexpr int kArenaSize = {{ arena_size }};
static constexpr int kMaxOps = {{ resolver_max_ops }};
#if {{ resource_variable_count }} > 0
static constexpr int kNumResourceVariables = {{ resource_variable_count }};
#endif

{# Arena placement is driven by the resolved logical region from
   PlanMemoryStage. TCM is fastest (single-cycle, tightly-coupled);
   SRAM is shared on-bus memory. PSRAM is external and not in the
   linker MEMORY map, so the arena pointer is bound at runtime to a
   PSRAM offset right after PSRAM init (see main()). #}
{% if arena_region == "tcm" %}
NSX_MEM_FAST_BSS alignas(16) static uint8_t g_arena_storage[kArenaSize];
static uint8_t *g_arena = g_arena_storage;
{% elif arena_region == "sram" %}
NSX_MEM_SRAM_BSS alignas(16) static uint8_t g_arena_storage[kArenaSize];
static uint8_t *g_arena = g_arena_storage;
{% elif arena_region == "psram" %}
// Arena lives in external PSRAM; pointer bound after nsx_psram_init().
static uint8_t *g_arena = nullptr;
{% else %}
// Fallback: default BSS (typically TCM on AP5, otherwise main RAM)
alignas(16) static uint8_t g_arena_storage[kArenaSize];
static uint8_t *g_arena = g_arena_storage;
{% endif %}
static HpxPmuProfiler g_profiler;

// Register builtin ops using the selected resolver strategy.
static tflite::MicroMutableOpResolver<kMaxOps> &get_resolver() {
    static tflite::MicroMutableOpResolver<kMaxOps> r;
    static bool init = false;
    if (!init) {
{% if resolver_mode == "auto" %}
    // Auto mode narrows registrations to builtins observed in the model.
{% else %}
    // All mode keeps the broad fixed builtin surface for compatibility.
{% endif %}
{% for registration in resolver_registrations %}
    {{ registration }}
{% endfor %}
        init = true;
    }
    return r;
}

int main(void) {
    nsx_system_config_t sys_cfg = {};
    sys_cfg.perf_mode = {{ perf_mode_symbol }};  // {{ perf_mode_mhz }} MHz — target.clock.cpu
    sys_cfg.enable_cache = true;
    sys_cfg.enable_sram = true;
    sys_cfg.debug.transport = {% if transport == "swo" %}NSX_DEBUG_ITM{% else %}NSX_DEBUG_NONE{% endif %};
    sys_cfg.skip_bsp_init = false;
    sys_cfg.spot_mgr_profile = true;
    NSX_TRY(nsx_system_init(&sys_cfg), "System init failed\n");
{% if transport == "swo" %}
    nsx_itm_printf_enable();
{% endif %}
    dwt_init();
    sync_gpio_init();
{% include "_extreme_mode.j2" %}
{% if transport == "usb_cdc" %}

    // Initialize USB CDC and wait for host to connect (DTR)
    NSX_TRY(nsx_usb_init(&g_usb_cfg), "USB CDC init failed\n");
    while (!nsx_usb_connected(&g_usb_cfg)) {
        nsx_delay_us(HPX_USB_POLL_DELAY_US);
    }
    // Brief settling delay after host connects
    nsx_delay_us(HPX_USB_SETTLE_DELAY_US);
    dwt_init();
{% elif transport == "rtt" %}

    // Configure buffer 0 in non-blocking trim mode for the boot/timed phases
    // (writes that don't fit are dropped rather than stalling the CPU).
    // hpx_rtt_set_blocking() later switches to lossless blocking mode around
    // CSV dumps and HPX_END so no profiling row or the sentinel is ever lost.
    // BUFFER_SIZE_UP is set via CMake so _DoInit() already allocates the
    // compile-time buffer size. ConfigUpBuffer(0) can only change flags, not the
    // buffer pointer/size (SEGGER RTT design for the default terminal).
    SEGGER_RTT_ConfigUpBuffer(0, "HPX", NULL, 0,
                              SEGGER_RTT_MODE_NO_BLOCK_TRIM);
    // Flush the RTT control block metadata so J-Link can see the configured
    // buffer counts/flags before the host attaches on cached M55 targets.
    HPX_CLEAN_DCACHE();
    hpx_printf("HPX_READY\n");
    HPX_CLEAN_DCACHE();
    if (!hpx_rtt_wait_for_command("HPX_HOST_READY", HPX_RTT_HOST_READY_TIMEOUT_MS)) {
        hpx_printf("HPX_ERROR=rtt_host_ready_timeout\n");
        HPX_CLEAN_DCACHE();
        while (1) { __WFI(); }
    }
{% else %}

    // Delay to allow the host SWO viewer to attach after reset.
    // NSX owns the ITM/SWO bring-up when debug.transport=NSX_DEBUG_ITM.
    nsx_delay_us(HPX_SWO_ATTACH_DELAY_US);
{% endif %}

{% if psram_needed %}

    // Flush any pending data to SRAM before PSRAM init. The platform backend may invalidate D-cache during
    // am_hal_cachectrl_dcache_invalidate(NULL, true) which discards all
    // dirty D-cache lines.
    HPX_CLEAN_DCACHE();

    // --- PSRAM init ---
    // PSRAM is external (MSPI XIP) and is not in the linker MEMORY map,
    // so any allocations in PSRAM use a runtime base pointer assigned
    // here. Region layout:
    //   [base + 0]              : model data (when weights_region=psram)
    //   [base + arena_offset]   : tensor arena (when arena_region=psram)
    nsx_psram_config_t psram_cfg;
    nsx_psram_default_config(&psram_cfg);
    psram_cfg.enable_xip = true;
    if (nsx_psram_init(&psram_cfg) != 0) {
        hpx_printf("HPX_ERROR=psram_init_failed\n");
        HPX_CLEAN_DCACHE();
        while (1) { __WFI(); }
    }
{% if weights_region == "psram" %}
    model_data = (const unsigned char *)psram_cfg.base_address;
    // Align arena offset to 64 bytes (cacheline) past the model bytes.
    static constexpr uint32_t kArenaPsramOffset =
        ((uint32_t){{ model_size }} + 63u) & ~63u;
{% else %}
    static constexpr uint32_t kArenaPsramOffset = 0u;
{% endif %}
{% if arena_region == "psram" %}
    g_arena = (uint8_t *)(psram_cfg.base_address + kArenaPsramOffset);
    hpx_printf("HPX_PSRAM_ARENA=0x%08lx,%d\n",
               (unsigned long)g_arena, kArenaSize);
{% endif %}
{% if weights_region == "psram" %}
    hpx_printf("HPX_PSRAM_READY=0x%08lx,%u\n",
               (unsigned long)psram_cfg.base_address, model_data_len);
{% endif %}
    HPX_CLEAN_DCACHE();

{% if weights_region == "psram" and transport == "rtt" %}
    // Wait for host to write model data and send "GO" via RTT down-channel.
    {
        char go_buf[16] = {0};
        unsigned go_pos = 0;
        while (1) {
            unsigned n = SEGGER_RTT_Read(0, go_buf + go_pos,
                                         sizeof(go_buf) - 1 - go_pos);
            if (n > 0) {
                go_pos += n;
                go_buf[go_pos] = '\0';
                if (go_pos >= 6) break; // "HPX_GO" is 6 chars
            }
        }
        // Invalidate D-cache for PSRAM region so CPU reads fresh J-Link data.
        SCB_InvalidateDCache_by_Addr((void *)psram_cfg.base_address,
                                     (int32_t)model_data_len);
    }
{% endif %}
{% endif %}

    hpx_printf("\n--- HPX_START ---\n");
    hpx_printf("HPX_VERSION=1\n");
    hpx_printf("HPX_EXTREME_MODE=%d\n", {{ 1 if extreme_mode and arena_region == "tcm" and weights_region == "tcm" else 0 }});
    hpx_printf("HPX_MODEL_SIZE=%u\n", model_data_len);
    hpx_printf("HPX_ARENA_SIZE=%d\n", kArenaSize);
    hpx_printf("HPX_ITERATIONS={{ iterations }}\n");
    hpx_printf("HPX_WARMUP={{ warmup }}\n");
    hpx_printf("HPX_NUM_PRESETS=%d\n", {{ pmu_passes | length }});
    hpx_printf("HPX_PRESETS={{ pmu_pass_names | join(',') }}\n");
    hpx_printf("HPX_POWER_SYNC=%s\n", kPowerSyncEnabled ? "gpio" : "none");
    if constexpr (kPowerSyncEnabled) {
        hpx_printf("HPX_SYNC_GPIO=%lu\n", (unsigned long)kSyncGpioPin);
    }

    // --- Heartbeat config (emitted so the host knows what to expect) -----
    static constexpr bool     kHbEnabled    = {{ heartbeat_enabled | lower }};
    static constexpr int      kHbEveryNOps  = {{ heartbeat_every_n_ops }};
    static constexpr uint32_t kHbEveryMs    = {{ heartbeat_every_ms }};
    hpx_printf("HPX_HEARTBEAT_ENABLED=%d\n", (int)kHbEnabled);
    hpx_printf("HPX_HEARTBEAT_EVERY_N_OPS=%d\n", kHbEveryNOps);
    hpx_printf("HPX_HEARTBEAT_EVERY_MS=%lu\n", (unsigned long)kHbEveryMs);

    // Convert ms → DWT cycles for the profiler's cheap rollover-safe compare.
    // SystemCoreClock is in Hz; cycles_per_ms = SystemCoreClock / 1000.
    const uint32_t hb_every_cyc = kHbEnabled && kHbEveryMs > 0
        ? (uint32_t)((uint64_t)SystemCoreClock / 1000U * kHbEveryMs)
        : 0U;
    const int hb_every_ops = kHbEnabled ? kHbEveryNOps : 0;

    hpx_printf("HPX_HEARTBEAT phase=init t=0\n");

    tflite::InitializeTarget();

    const tflite::Model *model = tflite::GetModel(model_data);
    if (model->version() != TFLITE_SCHEMA_VERSION) {
        hpx_printf("HPX_ERROR=schema_mismatch:%lu_vs_%d\n",
                  model->version(), TFLITE_SCHEMA_VERSION);
        while (1) { __WFI(); }
    }

    // Use the first pass to allocate (all passes use the same model/arena)
{% if pmu_passes[0].custom %}
{% if has_armv8m_pmu %}
    {
        static const uint32_t _init_ids[] = { {{ pmu_passes[0].event_ids | join(', ') }} };
        static const char* _init_names[] = { {% for name in pmu_passes[0].counter_names %}"{{ name }}"{% if not loop.last %}, {% endif %}{% endfor %} };
        g_profiler.InitCustom(_init_ids, {{ pmu_passes[0].num_counters }});
        g_profiler.SetCounterNames(_init_names, {{ pmu_passes[0].num_counters }});
    }
{% else %}
    g_profiler.Init(0);
{% endif %}
{% else %}
{% if has_armv8m_pmu %}
    {
        static const char* _init_names[] = { {% for name in pmu_passes[0].counter_names %}"{{ name }}"{% if not loop.last %}, {% endif %}{% endfor %} };
        g_profiler.Init({{ pmu_passes[0].c_enum }});
        g_profiler.SetCounterNames(_init_names, {{ pmu_passes[0].num_counters }});
    }
{% else %}
    g_profiler.Init(0);
{% endif %}
{% endif %}
    g_profiler.SetHeartbeat(hb_every_cyc, hb_every_ops);

    hpx_printf("HPX_HEARTBEAT phase=allocate\n");
    auto &resolver = get_resolver();

    // --- Preflight: classify likely failure modes BEFORE AllocateTensors --
    // Walk operator codes; any unregistered op would make AllocateTensors
    // fail with a generic error the user commonly misreads as "arena too
    // small".  Emit a distinct HPX_ERROR so the real cause is obvious.
    {
        const auto *opcodes = model->operator_codes();
        const auto *subs = model->subgraphs();
        int missing = 0;
        if (opcodes != nullptr) {
            for (unsigned i = 0; i < opcodes->size(); ++i) {
                const tflite::OperatorCode *oc = opcodes->Get(i);
                const TFLMRegistration *reg = nullptr;
                tflite::BuiltinOperator b = tflite::GetBuiltinCode(oc);
                if (b == tflite::BuiltinOperator_CUSTOM) {
                    const char *cname = oc->custom_code() ? oc->custom_code()->c_str() : "";
                    reg = resolver.FindOp(cname);
                    if (reg == nullptr) {
                        hpx_printf("HPX_ERROR=unsupported_op kind=custom name=%s index=%u\n",
                                   cname[0] ? cname : "?", i);
                        ++missing;
                    }
                } else {
                    reg = resolver.FindOp(b);
                    if (reg == nullptr) {
                        hpx_printf("HPX_ERROR=unsupported_op kind=builtin "
                                   "builtin=%d name=%s index=%u\n",
                                   (int)b, tflite::EnumNameBuiltinOperator(b), i);
                        ++missing;
                    }
                }
            }
        }
        // Walk tensors for dtypes that commonly surprise users.
        if (subs != nullptr && subs->size() > 0) {
            const auto *tensors = subs->Get(0)->tensors();
            if (tensors != nullptr) {
                for (unsigned t = 0; t < tensors->size(); ++t) {
                    auto ty = tensors->Get(t)->type();
                    // Warn on anything outside the common integer-quant + float32 set.
                    switch (ty) {
                        case tflite::TensorType_FLOAT32:
                        case tflite::TensorType_INT8:
                        case tflite::TensorType_INT16:
                        case tflite::TensorType_INT32:
                        case tflite::TensorType_INT64:
                        case tflite::TensorType_UINT8:
                        case tflite::TensorType_BOOL:
                            break;
                        default:
                            hpx_printf("HPX_WARN=unusual_dtype tensor=%u dtype=%d name=%s\n",
                                       t, (int)ty, tflite::EnumNameTensorType(ty));
                            break;
                    }
                }
            }
        }
        if (missing > 0) {
            hpx_printf("HPX_ERROR=missing_ops count=%d hint=rebuild_with_op_registration\n",
                       missing);
            while (1) { __WFI(); }
        }
    }

#if {{ resource_variable_count }} > 0
    tflite::MicroAllocator *allocator = tflite::MicroAllocator::Create(g_arena, kArenaSize);
    tflite::MicroResourceVariables *resource_variables =
        tflite::MicroResourceVariables::Create(allocator, kNumResourceVariables);
    tflite::MicroInterpreter interpreter(model, resolver, allocator,
                                         resource_variables, &g_profiler);
#else
    tflite::MicroInterpreter interpreter(model, resolver, g_arena, kArenaSize,
                                         nullptr, &g_profiler);
#endif
    const TfLiteStatus alloc_status = interpreter.AllocateTensors();
    if (alloc_status != kTfLiteOk) {
        // At this point ops are known-registered, so the most likely causes
        // are (a) arena too small, or (b) a kernel Init/Prepare rejected
        // the op (shape/dtype/parameter mismatch).  We cannot cheaply
        // distinguish these from inside TFLM, so we report both options.
        hpx_printf("HPX_ERROR=alloc_tensors_failed arena=%d status=%d "
                   "hint=arena_too_small_or_kernel_prepare_failed\n",
                   kArenaSize, (int)alloc_status);
        while (1) { __WFI(); }
    }
    hpx_printf("HPX_HEARTBEAT phase=allocated arena_used=%lu\n",
               (unsigned long)interpreter.arena_used_bytes());

    // --- Memory usage metadata ---
    TfLiteTensor *input = interpreter.input(0);
    TfLiteTensor *output = interpreter.output(0);
    hpx_printf("HPX_INPUT_SIZE=%d\n", (int)input->bytes);
    hpx_printf("HPX_OUTPUT_SIZE=%d\n", (int)output->bytes);
    hpx_printf("HPX_ALLOCATED_ARENA=%lu\n", (unsigned long)interpreter.arena_used_bytes());
    hpx_printf("HPX_NUM_TENSORS=%d\n", (int)model->subgraphs()->Get(0)->tensors()->size());
    hpx_printf("HPX_NUM_INPUTS=%d\n", (int)interpreter.inputs_size());
    hpx_printf("HPX_NUM_OUTPUTS=%d\n", (int)interpreter.outputs_size());

    // Target-side profiled inference timing (excludes CSV/transport output).
    uint64_t profiled_infer_cycles = 0;
    uint32_t profiled_infer_count = 0;

    // --- Multi-pass PMU profiling ---
    // Each pass configures a specific set of PMU counters.  When the user
    // requests more counters than fit in a single pass (4 with 32-bit
    // chaining), the profiler runs multiple passes and the host merges
    // the results.  Warmup iterations are repeated per-pass to ensure
    // stable cache / pipeline state.
{% for pass in pmu_passes %}
    hpx_printf("\n--- HPX_PRESET {{ pass.name }} ---\n");
{% if pass.custom %}
{% if has_armv8m_pmu %}
    {
        static const uint32_t _pass{{ loop.index0 }}_ids[] = { {{ pass.event_ids | join(', ') }} };
        static const char* _pass{{ loop.index0 }}_names[] = { {% for name in pass.counter_names %}"{{ name }}"{% if not loop.last %}, {% endif %}{% endfor %} };
        g_profiler.InitCustom(_pass{{ loop.index0 }}_ids, {{ pass.num_counters }});
        g_profiler.SetCounterNames(_pass{{ loop.index0 }}_names, {{ pass.num_counters }});
    }
{% else %}
    g_profiler.Init(0);
{% endif %}
{% else %}
{% if has_armv8m_pmu %}
    {
        static const char* _pass{{ loop.index0 }}_names[] = { {% for name in pass.counter_names %}"{{ name }}"{% if not loop.last %}, {% endif %}{% endfor %} };
        g_profiler.Init({{ pass.c_enum }});
        g_profiler.SetCounterNames(_pass{{ loop.index0 }}_names, {{ pass.num_counters }});
    }
{% else %}
    g_profiler.Init(0);
{% endif %}
{% endif %}
    // Init resets PMU state; re-arm heartbeat thresholds.
    g_profiler.SetHeartbeat(hb_every_cyc, hb_every_ops);

{% if transport == "usb_cdc" %}
    usb_timer_pause();
{% endif %}

    // Warmup for this pass (profiler disabled, no GPIO sync)
    for (int w = 0; w < {{ warmup }}; w++) {
        memset(input->data.raw, 0, input->bytes);
        interpreter.Invoke();
    }
    hpx_printf("HPX_HEARTBEAT phase=warmup_done pass={{ loop.index0 }}\n");

    // Profiled iterations — GPIO sync brackets each inference
    for (int iter = 0; iter < {{ iterations }}; iter++) {
        memset(input->data.raw, 0, input->bytes);
        g_profiler.ClearEvents();
        g_profiler.SetIterationContext({{ loop.index0 }}, iter);

        sync_gpio_high();
        uint32_t infer_start_cyc = DWT->CYCCNT;
        interpreter.Invoke();
        profiled_infer_cycles += (uint32_t)(DWT->CYCCNT - infer_start_cyc);
        profiled_infer_count++;
        sync_gpio_low();

{% if transport == "usb_cdc" %}
        usb_timer_resume();
{% elif transport == "rtt" %}
        // CSV dump is outside the timed window — make it lossless.
        hpx_rtt_set_blocking();
{% endif %}
        hpx_printf("\n--- HPX_ITER %d ---\n", iter);
        g_profiler.PrintCsv();
{% if transport == "usb_cdc" %}
        usb_timer_pause();
{% elif transport == "rtt" %}
        // Restore non-blocking before the next timed Invoke() so heartbeats
        // emitted mid-inference can never stall and skew measurements.
        hpx_rtt_set_nonblocking();
{% endif %}
    }

{% if transport == "usb_cdc" %}
    usb_timer_resume();
{% endif %}
{% endfor %}

    if (profiled_infer_count > 0 && SystemCoreClock > 0U) {
        const uint32_t profiled_infer_total_us = (uint32_t)(
            (profiled_infer_cycles * 1000000ULL + ((uint64_t)SystemCoreClock / 2ULL)) /
            (uint64_t)SystemCoreClock);
        const uint32_t profiled_infer_avg_us = (uint32_t)(
            (profiled_infer_cycles * 1000000ULL +
             (((uint64_t)SystemCoreClock * (uint64_t)profiled_infer_count) / 2ULL)) /
            ((uint64_t)SystemCoreClock * (uint64_t)profiled_infer_count));
        hpx_printf("HPX_PROFILED_INFER_COUNT=%lu\n", (unsigned long)profiled_infer_count);
        hpx_printf("HPX_PROFILED_INFER_TOTAL_US=%lu\n", (unsigned long)profiled_infer_total_us);
        hpx_printf("HPX_PROFILED_INFER_AVG_US=%lu\n", (unsigned long)profiled_infer_avg_us);
    }

{% if transport == "rtt" %}
    // All timed inference work is done — switch to lossless blocking mode so
    // the final sentinel can never be dropped, then flush and drain as a
    // belt-and-braces measure.  Emit a phase heartbeat so the host inactivity
    // timer refreshes while we drain.
    hpx_rtt_set_blocking();
    hpx_printf("HPX_HEARTBEAT phase=flushing\n");
    HPX_CLEAN_DCACHE();
    hpx_rtt_drain(500 /* ms */);
{% endif %}
    hpx_printf("\n--- HPX_END ---\n");
{% if transport == "rtt" %}
    HPX_CLEAN_DCACHE();
    hpx_rtt_drain(500 /* ms */);
{% endif %}
    while (1) { __WFI(); }
    return 0;
}
