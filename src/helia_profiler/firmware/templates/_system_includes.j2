{# _system_includes.j2 — shared transport/system includes for main templates. #}
#include "{{ cmsis_device_header }}"
#include "nsx_core.h"
#include "nsx_mem.h"
#include "nsx_system.h"
{% if power_sync_enabled %}
#include "nsx_gpio.h"
{% endif %}

// Unified SDK transition shim: some SDK drops still expose NS_TRY while
// newer ones renamed the helper to NSX_TRY. Accept either surface so the
// generated firmware builds across the supported registry revisions.
#if !defined(NSX_TRY) && defined(NS_TRY)
#define NSX_TRY NS_TRY
#endif

{% set _aot_sram_resident = ((arena_regions | default([])) | selectattr("placement", "equalto", "sram") | list | length) > 0 %}
{% set _sram_resident = (arena_region | default("") == "sram") or (weights_region | default("") == "sram") or _aot_sram_resident %}
{% if (extreme_mode and arena_region == "tcm" and weights_region == "tcm") or ((manages_shared_ssram_power | default(false)) and (_sram_resident or (force_shared_sram | default(false)))) %}
#include "am_hal_pwrctrl.h"
{% endif %}
{% if power_only | default(false) %}
{% elif transport == "usb_cdc" %}
#include "nsx_usb.h"
#include "am_hal_timer.h"
{% elif transport == "rtt" %}
#include "SEGGER_RTT.h"
{% endif %}
