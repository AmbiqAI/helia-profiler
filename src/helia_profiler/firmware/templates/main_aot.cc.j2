    // --- Clean end-to-end inference timing (no per-layer instrumentation) ---
    // The per-layer PMU passes below bracket every op (the model operator
    // callback resets/reads PMU counters), which perturbs caches/pipeline and
    // adds overhead the sum-of-layers cannot see.  To report the most
    // representative whole-model latency, run a warmed, UNinstrumented timing
    // pass FIRST: prime caches with warmup iterations, then DWT-time clean
    // model_run()s with the profiler disabled.  Emitted as HPX_CLEAN_INFER_* —
    // these never replace the per-layer numbers, they sit alongside them for
    // comparison.
    //
    // This pass is also the canonical window for external power measurement:
    // it is the only inference loop free of instrumentation/transport overhead,
    // so the GPIO sync brackets it (not the instrumented passes below).  When
    // power sync is disabled, hpx_sync_window_begin/end compile to no-ops.
    {
        g_profiler_enabled = false;
{% if window_mode | default("fixed") == "auto" %}
        // Adaptive clean-window sizing.  Warm caches / branch predictor / MRAM
        // prefetch (uninstrumented) and capture the warm per-inference cycle
        // cost, then choose how many gated iterations to run so the window
        // fills ~{{ window_target_ms }} ms of wall-time, clamped to
        // [{{ window_min }}, {{ window_max }}].  Short models run more
        // iterations and big models fewer, giving a consistent window for
        // reliable external power gating.  The host divides the gated energy by
        // the reported HPX_CLEAN_INFER_COUNT.
        //
        // Robustness: a debugger attaching over SWD (notably the J-Link RTT
        // background engine) can reset/reconfigure DEMCR/DWT *after* our boot
        // dwt_init() runs, transiently freezing DWT->CYCCNT during an early
        // warmup iteration.  A frozen counter yields a near-zero cycle reading,
        // which would size the window to window_max (thousands of iterations →
        // minutes of silence that trip the host capture heartbeat).  The reset
        // is a single one-shot event during attach, so we re-assert the counter,
        // warm several times, and take the MAX reading: a transient freeze only
        // ever makes a reading too *low*, so the maximum rejects it.  If the
        // counter never advances at all we fall back to window_min.
        dwt_init();
        uint32_t clean_warm_cyc = 0U;
        for (int w = 0; w < 3; w++) {
            for (int i = 0; i < {{ aot_prefix }}_num_inputs; i++) {
                memset({{ aot_prefix }}_model_ctx.inputs[i].data, 0,
                       {{ aot_prefix }}_model_ctx.inputs[i].size);
            }
            uint32_t wt0 = DWT->CYCCNT;
            {{ aot_prefix }}_model_run(&{{ aot_prefix }}_model_ctx);
            uint32_t wc = (uint32_t)(DWT->CYCCNT - wt0);
            if (wc > clean_warm_cyc) clean_warm_cyc = wc;
        }
        int clean_iters_n = {{ window_min }};
        if (clean_warm_cyc > 0U) {
            const uint64_t target_cyc =
                ((uint64_t)SystemCoreClock / 1000ULL) * (uint64_t){{ window_target_ms }}U;
            uint64_t n = target_cyc / (uint64_t)clean_warm_cyc;
            if (n < {{ window_min }}ULL) n = {{ window_min }}ULL;
            if (n > {{ window_max }}ULL) n = {{ window_max }}ULL;
            clean_iters_n = (int)n;
        }
{% else %}
        // Warm caches / branch predictor / MRAM prefetch (uninstrumented).
        for (int w = 0; w < {{ clean_warmup | default(1) }}; w++) {
            for (int i = 0; i < {{ aot_prefix }}_num_inputs; i++) {
                memset({{ aot_prefix }}_model_ctx.inputs[i].data, 0,
                       {{ aot_prefix }}_model_ctx.inputs[i].size);
            }
            {{ aot_prefix }}_model_run(&{{ aot_prefix }}_model_ctx);
        }
        const int clean_iters_n = {{ clean_iters | default(1) }};
{% endif %}
        // Announce the upcoming silent clean (power) window so the host can
        // widen its capture deadline for the blackout.  Firmware only reports
        // state + the one runtime scalar the host cannot know a priori — how
        // long a single inference takes — folded into est_ms (iters * warm
        // cycles / clock).  The host owns the actual timeout policy.
{% if window_mode | default("fixed") == "auto" %}
        uint64_t clean_est_ms = 0;
        if (SystemCoreClock >= 1000U) {
            clean_est_ms = ((uint64_t)clean_iters_n * (uint64_t)clean_warm_cyc)
                           / ((uint64_t)SystemCoreClock / 1000ULL);
        }
        hpx_printf("HPX_HEARTBEAT phase=clean_window_begin iters=%d est_ms=%llu\n",
                   clean_iters_n, (unsigned long long)clean_est_ms);
{% else %}
        // Fixed window: no runtime warm measurement, so est_ms=0 — the host
        // already knows the iteration count from its own settings.
        hpx_printf("HPX_HEARTBEAT phase=clean_window_begin iters=%d est_ms=0\n",
                   clean_iters_n);
{% endif %}
        uint64_t clean_cycles = 0;
        uint32_t clean_count = 0;
        // Assert READY only after initialization and adaptive warmup. This
        // keeps host GO low until the firmware can enter the measured window.
        hpx_sync_ready();
        hpx_sync_wait_go();
        // Set the inputs once before the gated window, not on every
        // iteration — AutoDeploy's power loop re-invokes on the same fixed
        // input every run rather than re-zeroing it each time, and
        // re-memset()ing per iteration adds real, avoidable overhead inside
        // the timed/measured window (a measurable share of per-inference
        // energy for a small KWS model; found 2026-07-02 while diagnosing
        // the HPX-vs-AutoDeploy power gap).
        for (int i = 0; i < {{ aot_prefix }}_num_inputs; i++) {
            memset({{ aot_prefix }}_model_ctx.inputs[i].data, 0,
                   {{ aot_prefix }}_model_ctx.inputs[i].size);
        }
{% if clean_window_probe | default("infer") == "busy_loop" %}
        // Calibrate the busy-loop nop count BEFORE the PMU/debug domain is
        // disabled below.  DWT lives in the same CoreSight debug power
        // domain that am_hal_debug_disable() gates off — reading
        // DWT->CYCCNT while that domain is disabled reads a frozen value, so
        // a live "while (DWT->CYCCNT - t0 < target) nop();" loop as the
        // window's exit condition hangs forever once the domain is off
        // (found 2026-07-03: real firmware hang, required a J-Link reset to
        // recover the board).  Instead, measure nops-per-cycle once here
        // (domain still powered), then run a plain bounded counter loop with
        // no DWT reads at all inside the disabled window.
        uint32_t busy_calib_t0 = DWT->CYCCNT;
        volatile uint32_t busy_calib_i = 0;
        for (; busy_calib_i < 100000U; busy_calib_i++) {
            __asm volatile("nop");
        }
        uint32_t busy_calib_cyc = (uint32_t)(DWT->CYCCNT - busy_calib_t0);
        const uint64_t clean_probe_target_cyc =
            ((uint64_t)SystemCoreClock / 1000ULL) * (uint64_t){{ window_target_ms }}U;
        uint32_t busy_loop_iters = 100000U;
        if (busy_calib_cyc > 0U) {
            const uint64_t scaled =
                ((uint64_t)busy_calib_i * clean_probe_target_cyc) / (uint64_t)busy_calib_cyc;
            busy_loop_iters = (scaled > 0xFFFFFFFFULL) ? 0xFFFFFFFFU : (uint32_t)scaled;
        }
{% endif %}
{% if transport == "usb_cdc" and not power_only | default(false) %}
        // Silence the 1 kHz tud_task() polling timer for the duration of the
        // clean window.  Its ISR otherwise fires mid-inference and pollutes the
        // E2E cycle count (and the external-power window) — this adds measurable
        // per-inference latency overhead on DWT-timer parts (AP4).  The PMU
        // window below already does this.
        usb_timer_pause();
{% endif %}
{% set gate_dbg = (clean_window_probe | default("infer") == "busy_loop") or (gate_debug_domain_in_window | default(false)) %}
{% set use_stimer_window = (clean_window_timer | default("dwt") == "stimer") and (clean_window_probe | default("infer") != "busy_loop") %}
{% if transport == "uart" and not power_only | default(false) %}
        // The UART peripheral (PWRSTUART0-3) lives in the peripheral device
        // power domain, NOT the debug domain am_hal_debug_disable() below
        // gates -- it stays powered for the whole run otherwise.  This
        // measurably inflates current on AP5 EVBs (UART0-3 all ON during the
        // gated window per a live PWRCTRL->DEVPWRSTATUS snapshot) vs RTT's
        // zero-peripheral window.  AutoDeploy's power firmware has
        // bNeedAlternativeUART=false and never enables this at all.
        nsx_uart_printf_disable();
{% elif transport == "swo" and not power_only | default(false) %}
        // ITM/SWO's own enable request can hold PD_DBG powered independently
        // of am_hal_debug_disable() below, the same way the ARM PMU's
        // counters do (see the has_armv8m_pmu comment) -- this is a measurable
        // current increase on an AP510 EVB, matching the known PD_DBG cost,
        // even though
        // am_hal_debug_disable() already runs for this family/probe.
        // Dropping ITM here lets that call actually release the domain.
        nsx_itm_printf_disable();
{% endif %}
{% if has_armv8m_pmu %}
        // nsx_pmu_init() (already called above to configure the per-layer PMU
        // presets) leaves the ARM PMU counters running and the
        // AM_HAL_PWRCTRL_PERIPH_DEBUG power domain powered (via
        // am_hal_debug_enable()) for the rest of firmware execution —
        // g_profiler_enabled=false only gates software instrumentation, it
        // never touches this hardware.  AutoDeploy's power firmware never
        // calls any PMU code, so it never powers this domain at all.
        //
        // Releasing the PMU counters for the gated/clean window still avoids
        // PMU traffic during the measurement.  On families where
        // clean_window_timer=="stimer" (Apollo5), the in-window timer no
        // longer lives in the debug power domain (STIMER runs off its own
        // XTAL), so PD_DBG can be gated off for the *default* infer probe
        // too, not just the opt-in busy_loop probe — closing most of a
        // measurable current gap vs the reference baseline (which never powers this
        // domain at all).  Families still timing the window with DWT
        // (clean_window_timer=="dwt": Apollo3/Apollo4) keep the domain
        // powered for the infer probe, same as before.
        nsx_ambiq_pmu_disable();
{% if gate_dbg %}
        am_hal_debug_disable();
{% endif %}
{% endif %}
{% if use_stimer_window %}
        hpx_stimer_init();
        uint32_t clean_stimer_t0 = hpx_stimer_ticks();
{% endif %}
