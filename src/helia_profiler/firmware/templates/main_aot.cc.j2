    hpx_printf("HPX_NUM_INPUTS=%d\n", {{ aot_prefix }}_num_inputs);
    hpx_printf("HPX_NUM_OUTPUTS=%d\n", {{ aot_prefix }}_num_outputs);
    // Ground-truth CPU clock as actually configured on-device.  The host uses
    // this to verify its registry assumption (used for SWO baud + cycle->time
    // math) matches reality instead of trusting a hardcoded frequency.
    hpx_printf("HPX_SYSTEM_CLOCK_HZ=%lu\n", (unsigned long)SystemCoreClock);
{% if apollo3_burst %}
    hpx_printf("HPX_BURST_AVAIL=%d\n", hpx_burst_avail);
    hpx_printf("HPX_BURST_ENGAGED=%d\n", hpx_burst_engaged);
{% endif %}
    for (int i = 0; i < {{ aot_prefix }}_num_inputs; i++) {
