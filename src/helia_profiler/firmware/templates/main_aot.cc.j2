            // cycles from SystemCoreClock so the HPX_CLEAN_INFER_* wire
            // protocol and host parser (capture/parser.py) stay unchanged —
            // those two fields are informational/derived on this path, not
            // independently measured.
            const uint32_t clean_avg_us =
                (uint32_t)((clean_stimer_total_us + (clean_count / 2U)) / clean_count);
            const uint32_t clean_avg_cycles = (uint32_t)(
                ((uint64_t)clean_avg_us * (uint64_t)SystemCoreClock) / 1000000ULL);
            const uint64_t clean_cycles_reported =
                (uint64_t)clean_avg_cycles * (uint64_t)clean_count;
            hpx_printf("HPX_CLEAN_INFER_COUNT=%lu\n", (unsigned long)clean_count);
            hpx_printf("HPX_CLEAN_INFER_TOTAL_CYCLES=%llu\n",
                       (unsigned long long)clean_cycles_reported);
            hpx_printf("HPX_CLEAN_INFER_AVG_CYCLES=%lu\n",
                       (unsigned long)clean_avg_cycles);
            hpx_printf("HPX_CLEAN_INFER_AVG_US=%lu\n",
                       (unsigned long)clean_avg_us);
{% else %}
            const uint32_t clean_avg_cycles =
                (uint32_t)((clean_cycles + (clean_count / 2U)) / clean_count);
            hpx_printf("HPX_CLEAN_INFER_COUNT=%lu\n", (unsigned long)clean_count);
            hpx_printf("HPX_CLEAN_INFER_TOTAL_CYCLES=%llu\n",
                       (unsigned long long)clean_cycles);
            hpx_printf("HPX_CLEAN_INFER_AVG_CYCLES=%lu\n",
                       (unsigned long)clean_avg_cycles);
            if (SystemCoreClock > 0U) {
                const uint32_t clean_avg_us = (uint32_t)(
                    ((uint64_t)clean_avg_cycles * 1000000ULL +
                     ((uint64_t)SystemCoreClock / 2ULL)) /
                    (uint64_t)SystemCoreClock);
                hpx_printf("HPX_CLEAN_INFER_AVG_US=%lu\n",
                           (unsigned long)clean_avg_us);
            }
{% endif %}
        }
{% if power_only | default(false) %}
{% include "_power_terminal_success.j2" with context %}
{% endif %}
    }

{% if power_only | default(false) %}
{% else %}{% if transport == "rtt" %}
