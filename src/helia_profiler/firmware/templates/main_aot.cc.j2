// --- Boot-time host-attach delays (microseconds) ---
// These are the few unavoidable firmware-side waits where the host has no
// observable signal to poll: the host SWO/ITM viewer needs time to attach
// after reset, and USB CDC needs a brief settle after the host asserts DTR.
// Keep them named here so they stay discoverable and do not accrete as bare
// magic numbers throughout main().  The host side polls wherever it can
// (see capture/readiness.py); these cover only the genuinely-blind windows.
// SWO/ITM has no back-pressure, so a one-shot "delay then print the header"
// races the host's attach+enable: when the host enables SWO a hair late the
// HPX_START sentinel has already been clocked into the undrained ITM FIFO and
// is lost (the host then catches the stream from the second line on).  Emit
// disposable HPX_READY sync lines across the whole attach window instead; once
// the host enables SWO mid-preamble it stays synced and draining, so the real
// HPX_START header is guaranteed to be captured.  The parser ignores every
// line before "--- HPX_START ---".
#define HPX_SWO_SYNC_PREAMBLE_LINES  40            // disposable sync lines before the header
#define HPX_SWO_SYNC_GAP_US          (20U * 1000U) // gap per sync line (~800ms total grace)
#define HPX_USB_POLL_DELAY_US     (10U * 1000U)   // re-poll cadence while waiting for DTR
#define HPX_USB_SETTLE_DELAY_US   (200U * 1000U)  // settle after host asserts DTR
// UART/ITM re-enable settle: nsx_uart_printf_enable()/nsx_itm_printf_enable()
// re-powers the peripheral (clock/FIFO bring-up) right before the very next
// hpx_printf() call reports the clean-window results -- with zero settle
// margin that first line (HPX_CLEAN_INFER_COUNT=...) can be dropped or
// garbled, silently losing clean_infer_count and falling the host back to
// an unrelated whole-capture-window power estimate (found 2026-07-06 on the
// first hardware test of the UART teardown fix). 5ms is generous versus a
// UART/ITM clock-domain-crossing settle.
#define HPX_DEBUG_REENABLE_SETTLE_US (5U * 1000U)

