{# main_aot.cc — heliaPROFILER firmware for heliaAOT engine #}
/**
 * @file main.cc
 * @brief heliaPROFILER firmware (heliaAOT) — auto-generated, do not edit.
 *
 * Runs AOT-compiled inference with per-layer PMU profiling via the model
 * operator callback.  Emits CSV results over {{ transport | upper }} for the host-side
 * capture stage to parse.
 */

#include <cstdint>
#include <cstdio>
#include <cstdarg>
#include <cstring>

// Pre-include arm_mve.h in C++ context so that hpx_common.h's extern "C"
// re-inclusion is a harmless no-op (avoids overload conflicts with GCC 14).
#if defined(__ARM_FEATURE_MVE)
#include <arm_mve.h>
#endif

// heliaAOT model API
#include "{{ aot_prefix }}_model.h"
#include "{{ aot_prefix }}_common.h"

{% if has_armv8m_pmu %}
#include "nsx_pmu_utils.h"
#include "nsx_pmu_map.h"
{% endif %}

{% set psram_arena_needed = (arena_regions | selectattr("placement", "equalto", "psram") | list | length) > 0 %}
{% set psram_needed = (arena_region == "psram") or (weights_region == "psram") or psram_arena_needed %}
{% if psram_needed %}
#include "nsx_psram.h"
{% endif %}

{% include "_system_includes.j2" %}

#if defined(NSX_HAS_CACHE) && NSX_HAS_CACHE
#include "am_hal_cachectrl.h"
#define HPX_CLEAN_DCACHE() ((void)am_hal_cachectrl_dcache_clean(NULL))
#else
#define HPX_CLEAN_DCACHE() ((void)0)
#endif

// --- Boot-time host-attach delays (microseconds) ---
// These are the few unavoidable firmware-side waits where the host has no
// observable signal to poll: the host SWO/ITM viewer needs time to attach
// after reset, and USB CDC needs a brief settle after the host asserts DTR.
// Keep them named here so they stay discoverable and do not accrete as bare
// magic numbers throughout main().  The host side polls wherever it can
// (see capture/readiness.py); these cover only the genuinely-blind windows.
#define HPX_SWO_ATTACH_DELAY_US   (500U * 1000U)  // host SWO viewer attach grace
#define HPX_USB_POLL_DELAY_US     (10U * 1000U)   // re-poll cadence while waiting for DTR
#define HPX_USB_SETTLE_DELAY_US   (200U * 1000U)  // settle after host asserts DTR

{% if not allocate_arenas %}
{% for region in arena_regions %}
{% if region.blob_filename %}
#include "hpx_const_blob_{{ region.region_id }}.h"
{% endif %}
{% endfor %}
{% endif %}

// ---------------------------------------------------------------------------
// DWT cycle counter
// ---------------------------------------------------------------------------
{% include "_dwt_init.j2" %}

// ---------------------------------------------------------------------------
// GPIO sync for external power measurement
// ---------------------------------------------------------------------------
{% include "_gpio_sync.j2" %}

// ---------------------------------------------------------------------------
// PMU profiler — per-operator recording via AOT callback
// ---------------------------------------------------------------------------
// Large proxy models can compile to well over 2048 operators; keep enough
// headroom here to avoid silently truncating the capture stream.
static constexpr int kMaxLayers = 4096;
static constexpr int kMaxEvents = 4;

struct HpxLayerRecord {
    uint32_t counters[kMaxEvents];
    bool overflow;
};

{% if has_armv8m_pmu %}
static nsx_pmu_config_t g_pmu_cfg;
{% else %}
static uint32_t g_op_start_cyccnt = 0;
{% endif %}
static HpxLayerRecord g_layers[kMaxLayers];
static int g_num_layers = 0;
static int g_num_counters = 0;
static bool g_profiler_enabled = false;

// Heartbeat state — cheap counters/timestamps updated on each op finish so
// the host can detect a hung run without wall-clock timeouts.
static uint32_t g_hb_every_cyc = 0;
static int      g_hb_every_ops = 0;
static uint32_t g_hb_last_cyc = 0;
static int      g_hb_ops_since = 0;
static int      g_hb_pass = 0;
static int      g_hb_iter = 0;

{% include "_hpx_printf.j2" with context %}

{% if transport == "usb_cdc" %}
{% include "_usb_timer.j2" %}
{% endif %}


// ---------------------------------------------------------------------------
// AOT operator name table — extracted from the AIR graph by heliaPROFILER.
// Maps sequential execution index → operator type string.
// heliaAOT may fuse/remove ops, so this reflects the *actual* compiled graph.
// ---------------------------------------------------------------------------
{% if aot_op_manifest %}
static constexpr int kNumAotOps = {{ aot_op_manifest | length }};
struct AotOpInfo {
    int32_t id;           // AIR operator ID (callback value)
    const char *op_type;  // e.g. "CONV_2D", "FULLY_CONNECTED"
};
static const AotOpInfo kAotOps[kNumAotOps] = {
{% for op in aot_op_manifest %}
    { {{ op.id }}, "{{ op.op_type | upper }}" },
{% endfor %}
};

static const char *aot_op_name(int layer_idx) {
    if (layer_idx >= 0 && layer_idx < kNumAotOps) return kAotOps[layer_idx].op_type;
    return "unknown";
}

static int32_t aot_op_id(int layer_idx) {
    if (layer_idx >= 0 && layer_idx < kNumAotOps) return kAotOps[layer_idx].id;
    return layer_idx;
}
{% else %}
// No operator manifest available — fall back to index-based names.
static const char *aot_op_name(int /*layer_idx*/) { return "op"; }
static int32_t aot_op_id(int layer_idx) { return layer_idx; }
{% endif %}

{% if has_armv8m_pmu %}
static void profiler_init_preset(nsx_pmu_preset_e preset) {
    nsx_pmu_reset_config(&g_pmu_cfg);
    g_pmu_cfg.api = &nsx_pmu_V1_0_0;
    nsx_pmu_apply_preset(&g_pmu_cfg, preset);
    nsx_pmu_init(&g_pmu_cfg);
    g_num_counters = 0;
    for (int i = 0; i < kMaxEvents; i++) {
        if (g_pmu_cfg.events[i].enabled) g_num_counters++;
    }
}
{% else %}
static void profiler_init_preset(int) {
    g_num_counters = 1;
}
{% endif %}

{% if has_armv8m_pmu %}
static void profiler_init_custom(const uint32_t event_ids[], int num_events) {
    nsx_pmu_reset_config(&g_pmu_cfg);
    g_pmu_cfg.api = &nsx_pmu_V1_0_0;
    int n = (num_events > kMaxEvents) ? kMaxEvents : num_events;
    for (int i = 0; i < n; i++) {
        nsx_pmu_event_create(&g_pmu_cfg.events[i], event_ids[i],
                            NSX_PMU_EVENT_COUNTER_SIZE_32);
    }
    nsx_pmu_init(&g_pmu_cfg);
    g_num_counters = n;
}
{% else %}
static void profiler_init_custom(const uint32_t[], int) {
    profiler_init_preset(0);
}
{% endif %}

static void profiler_clear(void) {
    g_num_layers = 0;
}

static void profiler_print_csv(void) {
    if (g_num_layers == 0) return;
    hpx_printf("\"Layer\",\"Op\"");
{% if has_armv8m_pmu %}
    for (int e = 0; e < g_num_counters; e++) {
        if (!g_pmu_cfg.events[e].enabled) break;
        uint32_t map_idx = g_pmu_cfg.counter[e].mapIndex;
        if (map_idx < NSX_PMU_MAP_SIZE)
            hpx_printf(",\"%s\"", nsx_pmu_map[map_idx].regname);
        else
            hpx_printf(",\"event_%d\"", e);
    }
{% else %}
    hpx_printf(",\"ARM_PMU_CPU_CYCLES\"");
{% endif %}
    hpx_printf(",\"overflow\"\n");
    for (int i = 0; i < g_num_layers; i++) {
        const auto &rec = g_layers[i];
        // Print: Layer index, Op type with AOT operator ID for uniqueness.
        // Format: "CONV_2D:3" — type:id, so the host can disambiguate
        // multiple operators of the same type.
        hpx_printf("%d,%s:%ld", i, aot_op_name(i), (long)aot_op_id(i));
        for (int e = 0; e < g_num_counters; e++) {
    {% if has_armv8m_pmu %}
            if (!g_pmu_cfg.events[e].enabled) break;
    {% endif %}
            hpx_printf(",%lu", (unsigned long)rec.counters[e]);
        }
        hpx_printf(",%d\n", rec.overflow ? 1 : 0);
    }
}

// ---------------------------------------------------------------------------
// AOT operator callback — PMU start/stop per operator
// ---------------------------------------------------------------------------
static void model_operator_cb(
    int32_t op,
    {{ aot_prefix }}_operator_state_t state,
    int32_t status,
    void *user_data
) {
    (void)op;
    (void)status;
    (void)user_data;

    if (!g_profiler_enabled) return;

    if (state == {{ aot_prefix }}_op_state_run_started) {
{% if has_armv8m_pmu %}
        // Reset PMU counters at the start of each operator
        uint32_t saved_cyccnt = DWT->CYCCNT;
        nsx_pmu_reset_counters();
        DWT->CYCCNT = saved_cyccnt;
#if (__CORTEX_M >= 55U)
        ARM_PMU_Set_CNTR_OVS(0xFFFFFFFFU);
#endif
{% else %}
    g_op_start_cyccnt = DWT->CYCCNT;
{% endif %}
    } else if (state == {{ aot_prefix }}_op_state_run_finished) {
        // Read PMU counters after each operator completes
        if (g_num_layers >= kMaxLayers) return;
        int idx = g_num_layers++;
{% if has_armv8m_pmu %}
        uint32_t saved_cyccnt = DWT->CYCCNT;
        nsx_pmu_get_counters(&g_pmu_cfg);
        DWT->CYCCNT = saved_cyccnt;
        for (int i = 0; i < g_num_counters; i++) {
            g_layers[idx].counters[i] = g_pmu_cfg.counter[i].counterValue;
        }
#if (__CORTEX_M >= 55U)
        uint32_t ovs = ARM_PMU_Get_CNTR_OVS();
        g_layers[idx].overflow = (ovs != 0);
        if (ovs) ARM_PMU_Set_CNTR_OVS(ovs);
#else
        g_layers[idx].overflow = false;
#endif
    {% else %}
        g_layers[idx].counters[0] = DWT->CYCCNT - g_op_start_cyccnt;
        g_layers[idx].overflow = false;
    {% endif %}
        // Heartbeat emission (inter-op gap, not contaminating a layer)
        ++g_hb_ops_since;
        const bool by_ops = (g_hb_every_ops > 0) &&
                            (g_hb_ops_since >= g_hb_every_ops);
        bool by_time = false;
        if (g_hb_every_cyc > 0) {
            uint32_t now = DWT->CYCCNT;
            uint32_t delta = now - g_hb_last_cyc;
            by_time = (delta >= g_hb_every_cyc);
        }
        if (by_ops || by_time) {
            hpx_printf("HPX_HEARTBEAT phase=infer pass=%d iter=%d layer=%d\n",
                       g_hb_pass, g_hb_iter, g_num_layers);
            g_hb_last_cyc = DWT->CYCCNT;
            g_hb_ops_since = 0;
        }
    }
}

// ---------------------------------------------------------------------------
// AOT model context with profiling callback
// ---------------------------------------------------------------------------
static {{ aot_prefix }}_model_context_t {{ aot_prefix }}_model_ctx = {
    .callback = model_operator_cb,
    .user_data = nullptr
};

int main(void) {
    nsx_system_config_t sys_cfg = {};
    sys_cfg.perf_mode = {{ perf_mode_symbol }};  // {{ perf_mode_mhz }} MHz — target.clock.cpu
    sys_cfg.enable_cache = true;
    sys_cfg.enable_sram = true;
    sys_cfg.debug.transport = {% if transport == "swo" %}NSX_DEBUG_ITM{% else %}NSX_DEBUG_NONE{% endif %};
    sys_cfg.skip_bsp_init = false;
    sys_cfg.spot_mgr_profile = true;
    NSX_TRY(nsx_system_init(&sys_cfg), "System init failed\n");
{% if transport == "swo" %}
    nsx_itm_printf_enable();
{% endif %}
    dwt_init();
    sync_gpio_init();
{% include "_extreme_mode.j2" %}
{% if transport == "usb_cdc" %}

    // Initialize USB CDC and wait for host to connect (DTR)
    nsx_usb_init(&g_usb_cfg);
    while (!nsx_usb_connected(&g_usb_cfg)) {
        nsx_delay_us(HPX_USB_POLL_DELAY_US);
    }
    // Brief settling delay after host connects
    nsx_delay_us(HPX_USB_SETTLE_DELAY_US);
{% elif transport == "rtt" %}

    // Set trim mode on buffer 0 (non-blocking — silently drops excess data).
    // BUFFER_SIZE_UP=32768 is set via CMake so _DoInit() already allocates
    // a 32 KB buffer.  ConfigUpBuffer(0) can only change flags, not the
    // buffer pointer/size (SEGGER RTT design for the default terminal).
    SEGGER_RTT_ConfigUpBuffer(0, "HPX", NULL, 0,
                              SEGGER_RTT_MODE_NO_BLOCK_TRIM);
    // Flush the RTT control block metadata so J-Link can see the configured
    // buffer counts/flags before the host attaches on cached M55 targets.
    HPX_CLEAN_DCACHE();
{% else %}

    // Delay to allow the host SWO viewer to attach after reset.
    // NSX owns the ITM/SWO bring-up when debug.transport=NSX_DEBUG_ITM.
    nsx_delay_us(HPX_SWO_ATTACH_DELAY_US);
{% endif %}

    hpx_printf("\n--- HPX_START ---\n");
    hpx_printf("HPX_VERSION=1\n");
    hpx_printf("HPX_ENGINE=helia_aot\n");
    hpx_printf("HPX_EXTREME_MODE=%d\n", {{ 1 if extreme_mode and arena_region == "tcm" and weights_region == "tcm" else 0 }});
    hpx_printf("HPX_ITERATIONS={{ iterations }}\n");
    hpx_printf("HPX_WARMUP={{ warmup }}\n");
    hpx_printf("HPX_NUM_PRESETS=%d\n", {{ pmu_passes | length }});
    hpx_printf("HPX_PRESETS={{ pmu_pass_names | join(',') }}\n");
    hpx_printf("HPX_POWER_SYNC=%s\n", kPowerSyncEnabled ? "gpio" : "none");
    if constexpr (kPowerSyncEnabled) {
        hpx_printf("HPX_SYNC_GPIO=%lu\n", (unsigned long)kSyncGpioPin);
    }

    // --- Heartbeat config (matches TFLM template for protocol consistency) --
    static constexpr bool     kHbEnabled   = {{ heartbeat_enabled | lower }};
    static constexpr int      kHbEveryNOps = {{ heartbeat_every_n_ops }};
    static constexpr uint32_t kHbEveryMs   = {{ heartbeat_every_ms }};
    hpx_printf("HPX_HEARTBEAT_ENABLED=%d\n", (int)kHbEnabled);
    hpx_printf("HPX_HEARTBEAT_EVERY_N_OPS=%d\n", kHbEveryNOps);
    hpx_printf("HPX_HEARTBEAT_EVERY_MS=%lu\n", (unsigned long)kHbEveryMs);
    g_hb_every_cyc = (kHbEnabled && kHbEveryMs > 0)
        ? (uint32_t)((uint64_t)SystemCoreClock / 1000U * kHbEveryMs)
        : 0U;
    g_hb_every_ops = kHbEnabled ? kHbEveryNOps : 0;

    hpx_printf("HPX_HEARTBEAT phase=init\n");

{% if not allocate_arenas and arena_regions %}
    // External arena mode: allocate and bind arena buffers before model_init.
    //
    // Each region has a "placement" (tcm | sram | psram | <default>) that
    // controls where its backing storage lives. PSRAM-placed regions are
    // assigned at runtime from the PSRAM base pointer (PSRAM is external
    // MSPI XIP and is not in the linker MEMORY map, so static .psram_bss
    // sections are not available).
{% set psram_arena_regions = arena_regions | selectattr("placement", "equalto", "psram") | list %}
{% for region in arena_regions %}
{% if region.placement == "psram" %}
    static uint8_t *hpx_arena_buf_{{ region.region_id }} = nullptr;
{% elif region.placement == "tcm" %}
    NSX_MEM_FAST_BSS alignas({{ region.alignment }}) static uint8_t hpx_arena_buf_storage_{{ region.region_id }}[{{ region.size }}];
    static uint8_t *hpx_arena_buf_{{ region.region_id }} = hpx_arena_buf_storage_{{ region.region_id }};
{% elif region.placement == "sram" %}
    NSX_MEM_SRAM_BSS alignas({{ region.alignment }}) static uint8_t hpx_arena_buf_storage_{{ region.region_id }}[{{ region.size }}];
    static uint8_t *hpx_arena_buf_{{ region.region_id }} = hpx_arena_buf_storage_{{ region.region_id }};
{% else %}
    alignas({{ region.alignment }}) static uint8_t hpx_arena_buf_storage_{{ region.region_id }}[{{ region.size }}];
    static uint8_t *hpx_arena_buf_{{ region.region_id }} = hpx_arena_buf_storage_{{ region.region_id }};
{% endif %}
{% endfor %}
{% if psram_arena_regions %}
    // PSRAM init for arena regions placed in PSRAM.
    HPX_CLEAN_DCACHE();
    {
        nsx_psram_config_t psram_cfg;
        nsx_psram_default_config(&psram_cfg);
        psram_cfg.enable_xip = true;
        if (nsx_psram_init(&psram_cfg) != 0) {
            hpx_printf("HPX_ERROR=psram_init_failed\n");
            HPX_CLEAN_DCACHE();
            while (1) { __WFI(); }
        }
        // Stack PSRAM-placed arenas at successive 64-byte aligned offsets.
        uint32_t psram_off = 0;
{% for region in psram_arena_regions %}
        psram_off = (psram_off + {{ region.alignment }} - 1u) & ~({{ region.alignment }}u - 1u);
        hpx_arena_buf_{{ region.region_id }} =
            (uint8_t *)(psram_cfg.base_address + psram_off);
        hpx_printf("HPX_PSRAM_ARENA_REGION=%d,0x%08lx,%u\n",
                   {{ region.region_id }},
                   (unsigned long)hpx_arena_buf_{{ region.region_id }},
                   (unsigned)({{ region.size }}));
        psram_off += (uint32_t){{ region.size }};
{% endfor %}
        HPX_CLEAN_DCACHE();
    }
{% endif %}
    {
        int32_t bind_status;
{% for region in arena_regions %}
        bind_status = {{ aot_prefix }}_bind_arena(
            ({{ aot_prefix }}_arena_region_t){{ region.region_id }},
            hpx_arena_buf_{{ region.region_id }},
            (size_t){{ region.size }}
        );
        if (bind_status != 0) {
            hpx_printf("HPX_ERROR=bind_arena_failed:%d:region=%d\n",
                       (int)bind_status, {{ region.region_id }});
            while (1) { __WFI(); }
        }
{% endfor %}
    }
    hpx_printf("HPX_ARENAS_BOUND=%d\n", {{ arena_regions | length }});

    // Load constant arena sidecar blobs into bound arena buffers.
    // The AOT compiler emits constant data (weights/biases) as binary
    // sidecar files — the profiler app embeds them into flash and
    // copies them into the arena buffers before model_init.
{% for region in arena_regions %}
{% if region.blob_filename %}
    memcpy(hpx_arena_buf_{{ region.region_id }},
           hpx_const_blob_{{ region.region_id }},
           sizeof(hpx_const_blob_{{ region.region_id }}));
    hpx_printf("HPX_CONST_BLOB_LOADED region=%d size=%u\n",
               {{ region.region_id }},
               (unsigned)sizeof(hpx_const_blob_{{ region.region_id }}));
{% endif %}
{% endfor %}
{% endif %}

    // Initialize AOT model
    int32_t aot_status = {{ aot_prefix }}_model_init(&{{ aot_prefix }}_model_ctx);
    if (aot_status != 0) {
        hpx_printf("HPX_ERROR=model_init_failed:%ld\n", (long)aot_status);
        while (1) { __WFI(); }
    }
    hpx_printf("HPX_HEARTBEAT phase=model_init_done\n");

    // Report model metadata
    hpx_printf("HPX_NUM_INPUTS=%d\n", {{ aot_prefix }}_num_inputs);
    hpx_printf("HPX_NUM_OUTPUTS=%d\n", {{ aot_prefix }}_num_outputs);
    for (int i = 0; i < {{ aot_prefix }}_num_inputs; i++) {
        hpx_printf("HPX_INPUT_%d_SIZE=%d\n", i,
                  (int){{ aot_prefix }}_model_ctx.inputs[i].size);
    }
    for (int i = 0; i < {{ aot_prefix }}_num_outputs; i++) {
        hpx_printf("HPX_OUTPUT_%d_SIZE=%d\n", i,
                  (int){{ aot_prefix }}_model_ctx.outputs[i].size);
    }

    // Target-side profiled inference timing (excludes CSV/transport output).
    uint64_t profiled_infer_cycles = 0;
    uint32_t profiled_infer_count = 0;

    // --- Multi-pass PMU profiling ---
{% for pass in pmu_passes %}
    hpx_printf("\n--- HPX_PRESET {{ pass.name }} ---\n");
{% if has_armv8m_pmu and pass.custom %}
    {
        static const uint32_t _pass{{ loop.index0 }}_ids[] = { {{ pass.event_ids | join(', ') }} };
        profiler_init_custom(_pass{{ loop.index0 }}_ids, {{ pass.num_counters }});
    }
{% else %}
    profiler_init_preset({{ pass.c_enum if has_armv8m_pmu else 0 }});
{% endif %}

{% if transport == "usb_cdc" %}
    usb_timer_pause();
{% endif %}

    // Warmup for this pass (profiler disabled, no GPIO sync)
    g_profiler_enabled = false;
    for (int w = 0; w < {{ warmup }}; w++) {
        for (int i = 0; i < {{ aot_prefix }}_num_inputs; i++) {
            memset({{ aot_prefix }}_model_ctx.inputs[i].data, 0,
                   {{ aot_prefix }}_model_ctx.inputs[i].size);
        }
        {{ aot_prefix }}_model_run(&{{ aot_prefix }}_model_ctx);
    }
    hpx_printf("HPX_HEARTBEAT phase=warmup_done pass={{ loop.index0 }}\n");

    // Profiled iterations — GPIO sync brackets each inference
    g_profiler_enabled = true;
    for (int iter = 0; iter < {{ iterations }}; iter++) {
        for (int i = 0; i < {{ aot_prefix }}_num_inputs; i++) {
            memset({{ aot_prefix }}_model_ctx.inputs[i].data, 0,
                   {{ aot_prefix }}_model_ctx.inputs[i].size);
        }
        profiler_clear();
        g_hb_pass = {{ loop.index0 }};
        g_hb_iter = iter;
        g_hb_last_cyc = DWT->CYCCNT;
        g_hb_ops_since = 0;

        sync_gpio_high();
        uint32_t infer_start_cyc = DWT->CYCCNT;
        {{ aot_prefix }}_model_run(&{{ aot_prefix }}_model_ctx);
        profiled_infer_cycles += (uint32_t)(DWT->CYCCNT - infer_start_cyc);
        profiled_infer_count++;
        sync_gpio_low();

{% if transport == "usb_cdc" %}
        usb_timer_resume();
{% endif %}
        hpx_printf("\n--- HPX_ITER %d ---\n", iter);
        profiler_print_csv();
{% if transport == "usb_cdc" %}
        usb_timer_pause();
{% endif %}
    }

{% if transport == "usb_cdc" %}
    usb_timer_resume();
{% endif %}
{% endfor %}

    if (profiled_infer_count > 0 && SystemCoreClock > 0U) {
        const uint32_t profiled_infer_total_us = (uint32_t)(
            (profiled_infer_cycles * 1000000ULL + ((uint64_t)SystemCoreClock / 2ULL)) /
            (uint64_t)SystemCoreClock);
        const uint32_t profiled_infer_avg_us = (uint32_t)(
            (profiled_infer_cycles * 1000000ULL +
             (((uint64_t)SystemCoreClock * (uint64_t)profiled_infer_count) / 2ULL)) /
            ((uint64_t)SystemCoreClock * (uint64_t)profiled_infer_count));
        hpx_printf("HPX_PROFILED_INFER_COUNT=%lu\n", (unsigned long)profiled_infer_count);
        hpx_printf("HPX_PROFILED_INFER_TOTAL_US=%lu\n", (unsigned long)profiled_infer_total_us);
        hpx_printf("HPX_PROFILED_INFER_AVG_US=%lu\n", (unsigned long)profiled_infer_avg_us);
    }

{% if transport == "rtt" %}
    // Before emitting the sentinel, flush cache and wait for the RTT up
    // buffer to drain — otherwise the trailing CSV burst may be full and
    // NO_BLOCK_TRIM would silently drop HPX_END.  Also emit a phase
    // heartbeat so the host inactivity timer refreshes while we drain.
    hpx_printf("HPX_HEARTBEAT phase=flushing\n");
    HPX_CLEAN_DCACHE();
    hpx_rtt_drain(500 /* ms */);
{% endif %}
    hpx_printf("\n--- HPX_END ---\n");
{% if transport == "rtt" %}
    HPX_CLEAN_DCACHE();
    hpx_rtt_drain(500 /* ms */);
{% endif %}
    while (1) { __WFI(); }
    return 0;
}
