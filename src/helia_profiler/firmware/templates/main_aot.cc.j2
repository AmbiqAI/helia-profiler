        // g_profiler_enabled), but the AOT runtime still dispatches it via
        // an indirect call for every operator start/finish
        // ({{ aot_prefix }}_model.c already null-checks ctx->callback before
        // calling it) -- AutoDeploy's power binary has no callback at all.
        // Drop to nullptr for the measured window; restored right after.
        {{ aot_prefix }}_model_ctx.callback = nullptr;
        hpx_sync_window_begin();
{% if clean_window_probe | default("infer") == "busy_loop" %}
        hpx_printf("HPX_CLEAN_WINDOW_PROBE=busy_loop\n");
