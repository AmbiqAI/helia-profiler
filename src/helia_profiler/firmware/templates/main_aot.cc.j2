        clean_cycles = clean_probe_target_cyc;
        clean_count = 1;
{% elif use_stimer_window %}
        // Timed via STIMER (see hpx_stimer_init above), not DWT->CYCCNT: PD_DBG
        // (and DWT with it) is disabled for this whole loop on this family, so
        // an in-window DWT read would read frozen.  A single before/after
        // STIMER read brackets the whole window rather than reading every
        // iteration — fewer peripheral accesses inside the timed loop and no
        // resolution concern at this scale (XTAL 32.768 kHz ticks are ~30.5us,
        // negligible against a multi-ms clean window).
        for (int iter = 0; iter < clean_iters_n; iter++) {
            {{ aot_prefix }}_model_run(&{{ aot_prefix }}_model_ctx);
            clean_count++;
{% if clean_window_trace | default(false) and transport not in ["swo", "uart"] %}
            // Sanity-check trace: prove the device is looping inferences for
            // the whole gated window.  Perturbs power — diagnostic use only.
            // Never emitted on SWO builds here: PD_DBG is disabled for this
            // whole loop, and a TPIU/ITM write while PD_DBG is off hangs the
            // part unconditionally (DS510 erratum ERR003).  Never emitted on
            // UART builds either: nsx_uart_printf_disable() above powers off
            // the UART peripheral for the same window.
            hpx_printf("HPX_CLEAN_ITER=%d\n", iter);
{% endif %}
        }
{% else %}
        for (int iter = 0; iter < clean_iters_n; iter++) {
            uint32_t t0 = DWT->CYCCNT;
            {{ aot_prefix }}_model_run(&{{ aot_prefix }}_model_ctx);
            clean_cycles += (uint32_t)(DWT->CYCCNT - t0);
            clean_count++;
{% if clean_window_trace | default(false) and transport not in ["swo", "uart"] %}
            // Sanity-check trace: prove the device is looping inferences for
            // the whole gated window.  Perturbs power — diagnostic use only.
            // Excluded on SWO/UART: their printf peripherals are disabled
            // above for the same window (nsx_itm/uart_printf_disable()).
            hpx_printf("HPX_CLEAN_ITER=%d\n", iter);
{% endif %}
        }
{% endif %}
        hpx_sync_window_end();
{% if use_stimer_window %}
        uint64_t clean_stimer_total_us =
            hpx_stimer_ticks_to_us((uint64_t)(uint32_t)(hpx_stimer_ticks() - clean_stimer_t0));
{% endif %}
{% if not power_only | default(false) %}        // Restore the per-op callback for the instrumented per-layer passes below.
        {{ aot_prefix }}_model_ctx.callback = model_operator_cb;
{% if has_armv8m_pmu %}
        // Restore PMU/debug state for the instrumented per-layer passes below.
{% if gate_dbg %}
        am_hal_debug_enable();
{% endif %}
        nsx_ambiq_pmu_enable();
{% endif %}
{% if transport == "uart" %}
        nsx_uart_printf_enable();
        nsx_delay_us(HPX_DEBUG_REENABLE_SETTLE_US);
{% elif transport == "swo" %}
        nsx_itm_printf_enable();
        nsx_delay_us(HPX_DEBUG_REENABLE_SETTLE_US);
{% endif %}
{% if transport == "usb_cdc" %}
        usb_timer_resume();
{% endif %}{% endif %}
        if (clean_count > 0) {
{% if use_stimer_window %}
            // Derive avg_us directly from the device-independent STIMER
