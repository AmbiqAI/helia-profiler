{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ambiqai.github.io/helia-profiler/schemas/result-manifest/v1.json",
  "title": "heliaPROFILER result manifest",
  "description": "A permissive, versioned envelope for one HPX result bundle.",
  "type": "object",
  "required": [
    "schema",
    "schema_version",
    "run_id",
    "timestamp",
    "hpx_version",
    "status",
    "validity",
    "issues",
    "provenance",
    "comparability",
    "artifacts"
  ],
  "properties": {
    "schema": {
      "const": "hpx.result-manifest"
    },
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "hpx_version": {
      "type": "string"
    },
    "status": {
      "enum": ["complete", "incomplete", "failed"]
    },
    "validity": {
      "enum": ["valid", "degraded", "invalid"]
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/issue"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "comparability": {
      "type": "object",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    },
    "bundle_type": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "required": ["code", "severity", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string"
        },
        "context": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "artifact": {
      "type": "object",
      "required": ["path", "media_type", "size_bytes", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "schema": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "optional": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
