{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ambiqai.github.io/helia-profiler/schemas/run-summary/v1.json",
  "title": "heliaPROFILER run summary",
  "type": "object",
  "required": [
    "schema",
    "schema_version",
    "engine",
    "layers",
    "total_cycles",
    "overflow_detected",
    "validity",
    "issues"
  ],
  "properties": {
    "schema": {"const": "hpx.run-summary"},
    "schema_version": {"const": 1},
    "engine": {"type": "string", "minLength": 1},
    "layers": {"type": "integer", "minimum": 0},
    "total_cycles": {"type": "number"},
    "overflow_detected": {"type": "boolean"},
    "validity": {"enum": ["valid", "degraded", "invalid"]},
    "issues": {"type": "array", "items": {"type": "object"}}
  },
  "additionalProperties": true
}
