{# heliaaot_attributes.h — memory placement macros for heliaAOT on Ambiq/NSX
   Force-preincluded (-include) before AOT-generated platform.h so that our
   definitions take precedence over the cmake-type no-op fallbacks.

   The section names mirror nsx_mem.h so that the linker places data in the
   same regions as the rest of the NSX application.  Macro names must match
   exactly what heliaAOT's tensors.c.j2 / operators emit via
   MemoryType.to_qualifiers(prefix, init, writable).

   CRITICAL:  If heliaAOT ever renames or adds new PUT_IN_* macros the
   profiler's pragma validation will emit a warning at build-prep time.
#}
#pragma once

/*
 * Auto-generated by heliaPROFILER — do not edit.
 * Memory placement macros: {{ prefix|upper }}_PUT_IN_* → Ambiq section attributes.
 */

/* ── Logging ─────────────────────────────────────────────────────────────── */

#ifndef {{ prefix|upper }}_PRINTF
#define {{ prefix|upper }}_PRINTF(...)   ((void)0)
#endif

/* ── Memory hooks ────────────────────────────────────────────────────────── */

/*
 * Apollo510 / Apollo510B  (Cortex-M55, ITCM + TCM + 3 MB Shared SRAM)
 * Apollo5A / Apollo5B     (Cortex-M55, ITCM + TCM + 3 MB Shared SRAM)
 */
#if defined(AM_PART_APOLLO510) || defined(AM_PART_APOLLO510B) \
 || defined(AM_PART_APOLLO5A)  || defined(AM_PART_APOLLO5B)

  /* DTCM — default .data/.bss is already in TCM, no attribute needed */
  #define {{ prefix|upper }}_PUT_IN_DTCM
  #define {{ prefix|upper }}_PUT_IN_DTCM_INIT

  /* SRAM — shared SRAM requires explicit section placement */
  #define {{ prefix|upper }}_PUT_IN_SRAM       __attribute__((section(".sram_bss")))
  #define {{ prefix|upper }}_PUT_IN_SRAM_INIT  __attribute__((section(".shared")))

  /* MRAM — const keeps data in .rodata (NVM/MRAM, no RAM copy) */
  #define {{ prefix|upper }}_PUT_IN_MRAM       const
  #define {{ prefix|upper }}_PUT_IN_MRAM_INIT  const

  /* PSRAM — fall back to shared SRAM (PSRAM not linker-mapped) */
  #define {{ prefix|upper }}_PUT_IN_PSRAM      __attribute__((section(".sram_bss")))
  #define {{ prefix|upper }}_PUT_IN_PSRAM_INIT __attribute__((section(".shared")))

  /* ITCM — tightly-coupled instruction memory */
  #define {{ prefix|upper }}_PUT_IN_ITCM       __attribute__((section(".itcm_text")))

/*
 * Apollo330P / Apollo510L  (Cortex-M55, DTCM overlay for code, no ITCM)
 */
#elif defined(AM_PART_APOLLO330P) || defined(AM_PART_APOLLO510L)

  #define {{ prefix|upper }}_PUT_IN_DTCM
  #define {{ prefix|upper }}_PUT_IN_DTCM_INIT

  #define {{ prefix|upper }}_PUT_IN_SRAM       __attribute__((section(".sram_bss")))
  #define {{ prefix|upper }}_PUT_IN_SRAM_INIT  __attribute__((section(".shared")))

  #define {{ prefix|upper }}_PUT_IN_MRAM       const
  #define {{ prefix|upper }}_PUT_IN_MRAM_INIT  const

  #define {{ prefix|upper }}_PUT_IN_PSRAM      __attribute__((section(".sram_bss")))
  #define {{ prefix|upper }}_PUT_IN_PSRAM_INIT __attribute__((section(".shared")))

  /* Fast code → DTCM overlay (not ITCM, which doesn't exist) */
  #define {{ prefix|upper }}_PUT_IN_ITCM       __attribute__((section(".dtcm_text")))

/*
 * Apollo4P / Apollo4L  (Cortex-M4F, TCM + 1 MB Shared SRAM, no ITCM)
 */
#elif defined(AM_PART_APOLLO4P) || defined(AM_PART_APOLLO4L) || defined(AM_PART_APOLLO4)

  #define {{ prefix|upper }}_PUT_IN_DTCM
  #define {{ prefix|upper }}_PUT_IN_DTCM_INIT

  #define {{ prefix|upper }}_PUT_IN_SRAM       __attribute__((section(".sram_bss")))
  #define {{ prefix|upper }}_PUT_IN_SRAM_INIT  __attribute__((section(".shared")))

  #define {{ prefix|upper }}_PUT_IN_MRAM       const
  #define {{ prefix|upper }}_PUT_IN_MRAM_INIT  const

  #define {{ prefix|upper }}_PUT_IN_PSRAM
  #define {{ prefix|upper }}_PUT_IN_PSRAM_INIT

  /* No ITCM on Apollo4 — no-op (code stays in NVM .text) */
  #define {{ prefix|upper }}_PUT_IN_ITCM

/*
 * Apollo3P / Apollo3 Blue Plus  (Cortex-M4F, 64 KB TCM, no shared SRAM)
 */
#elif defined(AM_PART_APOLLO3P) || defined(AM_PART_APOLLO3)

  #define {{ prefix|upper }}_PUT_IN_DTCM
  #define {{ prefix|upper }}_PUT_IN_DTCM_INIT

  /* No shared SRAM concept on Apollo3 — fall back to default data region */
  #define {{ prefix|upper }}_PUT_IN_SRAM
  #define {{ prefix|upper }}_PUT_IN_SRAM_INIT

  #define {{ prefix|upper }}_PUT_IN_MRAM       const
  #define {{ prefix|upper }}_PUT_IN_MRAM_INIT  const

  #define {{ prefix|upper }}_PUT_IN_PSRAM
  #define {{ prefix|upper }}_PUT_IN_PSRAM_INIT

  /* TCM code section on Apollo3 */
  #define {{ prefix|upper }}_PUT_IN_ITCM       __attribute__((section(".tcm")))

/*
 * Unknown SoC — all macros become no-ops.  The profiler will warn about
 * this at build-preparation time.
 */
#else
  #warning "heliaPROFILER: unknown SoC — memory placement macros are no-ops"

  #define {{ prefix|upper }}_PUT_IN_DTCM
  #define {{ prefix|upper }}_PUT_IN_DTCM_INIT
  #define {{ prefix|upper }}_PUT_IN_SRAM
  #define {{ prefix|upper }}_PUT_IN_SRAM_INIT
  #define {{ prefix|upper }}_PUT_IN_MRAM       const
  #define {{ prefix|upper }}_PUT_IN_MRAM_INIT  const
  #define {{ prefix|upper }}_PUT_IN_PSRAM
  #define {{ prefix|upper }}_PUT_IN_PSRAM_INIT
  #define {{ prefix|upper }}_PUT_IN_ITCM

#endif
